<%# Flat card fragment for infinite-scroll fetch (no nested turbo-frames). %>
<div class="model-stream-page"
     data-page="<%= @models.current_page %>"
     data-next-url="<%= @models.next_page ? models_page_url(@models.next_page, @filter) : "" %>"
     data-has-more="<%= @models.next_page.present? %>">
  <% @models.each do |model| %>
    <%= render Components::ModelCard.new(model: model, eager_preview: false) %>
  <% end %>
</div>
