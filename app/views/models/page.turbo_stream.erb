<%# Insert cards BEFORE the sentinel so they stay siblings in the CSS grid. %>
<%= turbo_stream.before "models-scroll-sentinel" do %>
  <% @models.each do |model| %>
    <%= render Components::ModelCard.new(model: model, eager_preview: false, gallery: true) %>
  <% end %>
<% end %>

<%= turbo_stream.replace "models-scroll-sentinel" do %>
  <%= render "application/browse_scroll_sentinel",
        sentinel_id: "models-scroll-sentinel",
        next_url: browse_next_url(:models_path, filter: @filter) %>
<% end %>
