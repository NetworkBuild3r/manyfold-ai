<%= PageTitle title: t(".title"), breadcrumbs: {
      Model.model_name.human(count: 100) => models_path
    } %>

<p><%= t ".description" %></p>
<ul>
  <li><%= t ".archives-only" %></li>
  <li><%= t ".non-archives" %></li>
</ul>

<%= form_with model: @model, id: "upload-form", class: "max-w-2xl mx-auto tabular-form" do |form| %>

  <% if SiteSettings.show_libraries %>
    <div>
      <%= form.label :library, Library.model_name.human, class: "block text-sm font-medium text-secondary-700 dark:text-secondary-300" %>
    </div>
    <div>
      <%= form.select :library,
            policy_scope(Library).all.map { |lib| [library_select_title(lib), lib.to_param] },
            {selected: Library.default.to_param},
            {class: "block w-full rounded-lg border border-secondary-300 px-3 py-2 shadow-sm focus:ring-2 focus:ring-primary-500 dark:border-secondary-600 dark:bg-secondary-800"} %>
      <span class="text-sm text-secondary-500 dark:text-secondary-400 block mt-1"><%= t ".library.help" %></span>
    </div>
  <% end %>

  <div>
    <%= form.label :files, t(".files.label"), class: "block text-sm font-medium text-secondary-700 dark:text-secondary-300" %>
  </div>
  <div>
    <%= content_tag :div, nil, data: {
          turbo_permanent: true,
          controller: "upload",
          action: "turbo:morph@window->upload#reconnect",
          max_file_size: SiteSettings.max_file_upload_size,
          allowed_file_types: input_accept_string,
          archive_extensions: SupportedMimeTypes.archive_extensions.join(","),
          upload_endpoint: upload_path
        } %>

    <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-info/10 text-info mt-2 hidden" id="multi-model-message">
      <%= Icon(icon: "boxes", role: "presentation") %>
      <%= t(".multi_model") %>
    </div>

    <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-info/10 text-info mt-2 hidden" id="single-model-message">
      <%= Icon(icon: "box", role: "presentation") %>
      <%= t(".single_model") %>
    </div>
  </div>

  <%= text_input_row form, :name, label: t(".model_name.label"), help: t(".model_name.help") %>

  <%= render "bulk_fields", form: form %>

  <%= render "tags_edit", form: form, name: "model[tag_list]", selected: SiteSettings.model_tags_auto_tag_new, label: ActsAsTaggableOn::Tag.model_name.human(count: 100), tags: @available_tags || [] %>

  <div>
    <%= form.label translate(".permission_preset"), for: :permission_preset, class: "block text-sm font-medium text-secondary-700 dark:text-secondary-300" %>
  </div>
  <div>
    <%= form.select :permission_preset, [
          [translate("settings.multiuser.default_viewer_role.options.private"), "private"],
          [translate("settings.multiuser.default_viewer_role.options.member"), "member"],
          [translate("settings.multiuser.default_viewer_role.options.public"), "public"]
        ],
          {selected: SiteSettings.default_viewer_role},
          {class: "block w-full rounded-lg border border-secondary-300 px-3 py-2 shadow-sm focus:ring-2 focus:ring-primary-500 dark:border-secondary-600 dark:bg-secondary-800"} %>
  </div>

  <div class="mt-4">
    <%= submit_tag translate(".submit"), class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
  </div>
<% end %>
