<%= PageTitle title: t(".title"), breadcrumbs: {
      Model.model_name.human(count: 100) => models_path
    } %>

<p><%= t ".description" %></p>
<ul>
  <li><%= t ".archives-only" %></li>
  <li><%= t ".non-archives" %></li>
</ul>

<%= form_with model: @model, id: "upload-form", class: "tw:max-w-2xl tw:mx-auto tabular-form" do |form| %>

  <% if SiteSettings.show_libraries %>
    <div>
      <%= form.label :library, Library.model_name.human, class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
    </div>
    <div>
      <%= form.select :library,
            policy_scope(Library).all.map { |lib| [library_select_title(lib), lib.to_param] },
            {selected: Library.default.to_param},
            {class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800"} %>
      <span class="tw:text-sm tw:text-secondary-500 tw:dark:tw:text-secondary-400 tw:block tw:mt-1"><%= t ".library.help" %></span>
    </div>
  <% end %>

  <div>
    <%= form.label :files, t(".files.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
  </div>
  <div>
    <%= content_tag :div, nil, data: {
          turbo_permanent: true,
          controller: "upload",
          action: "turbo:morph@window->upload#reconnect",
          max_file_size: SiteSettings.max_file_upload_size,
          allowed_file_types: input_accept_string,
          archive_extensions: SupportedMimeTypes.archive_extensions.join(","),
          upload_endpoint: upload_path
        } %>

    <div class="tw:flex tw:items-center tw:gap-2 tw:px-4 tw:py-3 tw:rounded-lg tw:bg-info/10 tw:text-info tw:mt-2" id="multi-model-message" style="display: none">
      <%= Icon(icon: "boxes", role: "presentation") %>
      <%= t(".multi_model") %>
    </div>

    <div class="tw:flex tw:items-center tw:gap-2 tw:px-4 tw:py-3 tw:rounded-lg tw:bg-info/10 tw:text-info tw:mt-2" id="single-model-message" style="display: none">
      <%= Icon(icon: "box", role: "presentation") %>
      <%= t(".single_model") %>
    </div>
  </div>

  <%= text_input_row form, :name, label: t(".model_name.label"), help: t(".model_name.help") %>

  <%= render "bulk_fields", form: form %>

  <%= render "tags_edit", form: form, name: "model[tag_list]", selected: SiteSettings.model_tags_auto_tag_new, label: ActsAsTaggableOn::Tag.model_name.human(count: 100), tags: @available_tags || [] %>

  <div>
    <%= form.label translate(".permission_preset"), for: :permission_preset, class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
  </div>
  <div>
    <%= form.select :permission_preset, [
          [translate("settings.multiuser.default_viewer_role.options.private"), "private"],
          [translate("settings.multiuser.default_viewer_role.options.member"), "member"],
          [translate("settings.multiuser.default_viewer_role.options.public"), "public"]
        ],
          {selected: SiteSettings.default_viewer_role},
          {class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800"} %>
  </div>

  <div class="tw:mt-4">
    <%= submit_tag translate(".submit"), class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500" %>
  </div>
<% end %>
