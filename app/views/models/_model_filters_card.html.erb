<%# Full filter form in the models sidebar (not just search / tags). %>
<%
  fp = @filter&.to_params || {}
  has_image_on = ActiveModel::Type::Boolean.new.cast(@filter&.parameter(:has_image))
  select_class = "block w-full max-w-full min-w-0 rounded-lg border border-secondary-300 dark:border-secondary-600 dark:bg-secondary-800 dark:text-secondary-100 px-3 py-2 text-sm shadow-sm focus:ring-2 focus:ring-primary-500"
  label_class = "block text-sm font-medium text-secondary-700 dark:text-secondary-300 mb-1"
  input_class = select_class
%>
<%= card :secondary, t(".title", default: "Filter models") do %>
  <%= form_with url: models_path, method: :get, local: true, class: "space-y-3", html: {id: "models-filter-form"} do %>
    <%# Preserve sort + active tags across Apply %>
    <% if params[:order].present? %>
      <%= hidden_field_tag :order, params[:order] %>
    <% end %>
    <% if params[:direction].present? %>
      <%= hidden_field_tag :direction, params[:direction] %>
    <% end %>
    <% Array(fp[:tag]).compact_blank.each do |tag_name| %>
      <%= hidden_field_tag "tag[]", tag_name %>
    <% end %>
    <% if @filter&.filtering_by?(:list) %>
      <%= hidden_field_tag :list, @filter.parameter(:list) %>
    <% end %>

    <div>
      <label for="filter_q" class="<%= label_class %>"><%= t(".search", default: "Search") %></label>
      <%= text_field_tag :q, @filter&.parameter(:q),
            id: "filter_q",
            class: input_class,
            placeholder: t(".search_placeholder", default: "Name, notes…"),
            autocomplete: "off" %>
    </div>

    <%= turbo_frame_tag "model-filter-facets",
          src: filter_facets_models_path((@filter&.to_params || {}).except(:page)),
          loading: :lazy do %>
      <div class="space-y-3" aria-busy="true">
        <div class="h-16 rounded-lg bg-secondary-100 dark:bg-secondary-800 animate-pulse"></div>
        <div class="h-16 rounded-lg bg-secondary-100 dark:bg-secondary-800 animate-pulse"></div>
        <div class="h-16 rounded-lg bg-secondary-100 dark:bg-secondary-800 animate-pulse"></div>
      </div>
    <% end %>

    <div>
      <label for="filter_link" class="<%= label_class %>"><%= t(".link", default: "Link contains") %></label>
      <%= text_field_tag :link, (@filter&.parameter(:link) if @filter&.parameter(:link).present?),
            id: "filter_link",
            class: input_class,
            placeholder: t(".link_placeholder", default: "thingiverse.com…"),
            autocomplete: "off" %>
    </div>

    <div class="flex items-start gap-2 pt-1">
      <%= hidden_field_tag :has_image, "0", id: nil %>
      <%= check_box_tag :has_image, "1", has_image_on,
            id: "filter_has_image",
            class: "mt-1 rounded border-secondary-300 text-primary-600 focus:ring-primary-500 h-4 w-4" %>
      <label for="filter_has_image" class="text-sm text-secondary-800 dark:text-secondary-200 cursor-pointer">
        <span class="font-medium"><%= t("models.list.has_image_filter", default: "With images only") %></span>
        <span class="block text-xs text-secondary-500 dark:text-secondary-400 mt-0.5">
          <%= t(".has_image_help", default: "Hide models with no image preview.") %>
        </span>
      </label>
    </div>

    <div class="flex flex-col gap-2 pt-2 min-w-0">
      <button type="submit" class="flex w-full max-w-full items-center justify-center px-3 py-2 text-sm font-medium rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500">
        <%= t(".apply", default: "Apply filters") %>
      </button>
      <%= link_to t(".clear", default: "Clear all"), models_path,
            class: "flex w-full max-w-full items-center justify-center px-3 py-2 text-sm font-medium rounded-lg border border-secondary-300 dark:border-secondary-500 bg-white dark:bg-secondary-800 text-secondary-800 dark:text-secondary-100 hover:bg-secondary-50 dark:hover:bg-secondary-700 no-underline focus-visible:ring-2 focus-visible:ring-primary-500" %>
    </div>
  <% end %>
<% end %>
