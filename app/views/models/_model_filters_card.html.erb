<%# Full filter form in the models sidebar (not just search / tags). %>
<%
  fp = @filter&.to_params || {}
  has_image_on = ActiveModel::Type::Boolean.new.cast(@filter&.parameter(:has_image))
  select_class = "block w-full rounded-lg border border-secondary-300 dark:border-secondary-600 dark:bg-secondary-800 dark:text-secondary-100 px-3 py-2 text-sm shadow-sm focus:ring-2 focus:ring-primary-500"
  label_class = "block text-sm font-medium text-secondary-700 dark:text-secondary-300 mb-1"
  input_class = select_class
%>
<%= card :secondary, t(".title", default: "Filter models"), collapse: "md" do %>
  <%= form_with url: models_path, method: :get, local: true, class: "space-y-3", html: {id: "models-filter-form"} do %>
    <%# Preserve sort + active tags across Apply %>
    <% if params[:order].present? %>
      <%= hidden_field_tag :order, params[:order] %>
    <% end %>
    <% if params[:direction].present? %>
      <%= hidden_field_tag :direction, params[:direction] %>
    <% end %>
    <% Array(fp[:tag]).compact_blank.each do |tag_name| %>
      <%= hidden_field_tag "tag[]", tag_name %>
    <% end %>

    <div>
      <label for="filter_q" class="<%= label_class %>"><%= t(".search", default: "Search") %></label>
      <%= text_field_tag :q, @filter&.parameter(:q),
            id: "filter_q",
            class: input_class,
            placeholder: t(".search_placeholder", default: "Name, notes…"),
            autocomplete: "off" %>
    </div>

    <% if @filter_libraries.present? && @filter_libraries.many? %>
      <div>
        <label for="filter_library" class="<%= label_class %>"><%= Library.model_name.human %></label>
        <select name="library" id="filter_library" class="<%= select_class %>">
          <option value="all" <%= "selected" unless @filter&.filtering_by?(:library) %>><%= t(".any", default: "Any") %></option>
          <% @filter_libraries.each do |lib| %>
            <option value="<%= lib.to_param %>" <%= "selected" if @filter&.parameter(:library).to_s == lib.to_param %>><%= lib.name %></option>
          <% end %>
        </select>
      </div>
    <% end %>

    <div>
      <label for="filter_creator" class="<%= label_class %>"><%= Creator.model_name.human %></label>
      <select name="creator" id="filter_creator" class="<%= select_class %>">
        <option value="all" <%= "selected" if @filter&.parameter(:creator).blank? %>><%= t(".any", default: "Any") %></option>
        <option value="" <%= "selected" if @filter&.parameter(:creator) == "" %>><%= t(".none", default: "None (unassigned)") %></option>
        <% (@filter_creators || []).each do |creator| %>
          <option value="<%= creator.to_param %>" <%= "selected" if @filter&.parameter(:creator).to_s == creator.to_param %>><%= creator.name.careful_titleize %></option>
        <% end %>
      </select>
    </div>

    <div>
      <label for="filter_collection" class="<%= label_class %>"><%= Collection.model_name.human %></label>
      <select name="collection" id="filter_collection" class="<%= select_class %>">
        <option value="all" <%= "selected" if @filter&.parameter(:collection).blank? %>><%= t(".any", default: "Any") %></option>
        <option value="" <%= "selected" if @filter&.parameter(:collection) == "" %>><%= t(".none", default: "None (unassigned)") %></option>
        <% (@filter_collections || []).each do |collection| %>
          <option value="<%= collection.to_param %>" <%= "selected" if @filter&.parameter(:collection).to_s == collection.to_param %>><%= collection.name %></option>
        <% end %>
      </select>
    </div>

    <div>
      <label for="filter_link" class="<%= label_class %>"><%= t(".link", default: "Link contains") %></label>
      <%= text_field_tag :link, (@filter&.parameter(:link) if @filter&.parameter(:link).present?),
            id: "filter_link",
            class: input_class,
            placeholder: t(".link_placeholder", default: "thingiverse.com…"),
            autocomplete: "off" %>
    </div>

    <div class="flex items-start gap-2 pt-1">
      <%= check_box_tag :has_image, "1", has_image_on,
            id: "filter_has_image",
            class: "mt-1 rounded border-secondary-300 text-primary-600 focus:ring-primary-500 h-4 w-4" %>
      <label for="filter_has_image" class="text-sm text-secondary-800 dark:text-secondary-200 cursor-pointer">
        <span class="font-medium"><%= t("models.list.has_image_filter", default: "With images only") %></span>
        <span class="block text-xs text-secondary-500 dark:text-secondary-400 mt-0.5">
          <%= t(".has_image_help", default: "Hide models with no image preview.") %>
        </span>
      </label>
    </div>

    <div class="flex flex-col gap-2 pt-2">
      <button type="submit" class="inline-flex w-full items-center justify-center px-3 py-2 text-sm font-medium rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500">
        <%= t(".apply", default: "Apply filters") %>
      </button>
      <%= link_to t(".clear", default: "Clear all"), models_path,
            class: "inline-flex w-full items-center justify-center px-3 py-2 text-sm font-medium rounded-lg border border-secondary-300 dark:border-secondary-500 bg-white dark:bg-secondary-800 text-secondary-800 dark:text-secondary-100 hover:bg-secondary-50 dark:hover:bg-secondary-700 no-underline focus-visible:ring-2 focus-visible:ring-primary-500" %>
    </div>
  <% end %>
<% end %>
