<% content_for :head do %>
  <%= tag.meta property: "og:type", content: "website" %>
  <%= tag.meta property: "og:image", content: model_model_file_url(@model, @model.preview_file, format: @model.preview_file.extension) if @model.preview_file&.is_image? && !@model.sensitive %>
  <%= tag.meta name: "description", content: truncate(sanitize(@model.notes), length: 80) if @model.notes.present? %>
  <%= tag.meta name: "fediverse:creator", content: @model.creator.federails_actor.at_address if @model.creator %>
  <%= tag.link rel: "alternate", type: Mime[:oembed], href: model_url(@model, format: :oembed), title: @model.name %>
<% end %>

<div itemscope itemtype="https://schema.org/3DModel">
  <%= turbo_stream_from @model %>

  <%= PageTitle title: @model.name, heading: false, breadcrumbs: {
        Model.model_name.human(count: 100) => models_path
      } %>

  <article>
    <section class="bg-secondary-900 dark:bg-secondary-950 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-6 mb-6" aria-label="Model preview">
      <%= ImageCarousel(images: @images) %>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6">
      <div class="min-w-0" id="item_list">
        <h1 class="font-display text-3xl font-semibold tracking-tight text-secondary-900 dark:text-secondary-100">
          <%= policy(@model).edit? ? EditableSpan(fieldname: "model[name]", path: model_path(@model), text: @model.name) : @model.name %>
          <%= link_to Icon(icon: "search", label: t(".search")),
                "https://yeggi.com/q/#{ERB::Util.url_encode(@model.name)}/",
                class: secondary_action_class, target: "manyfold_search", rel: "noreferrer" %>
        </h1>

        <% if @locked_files > 0 %>
          <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-info/10 text-info dark:bg-info/20 dark:text-info mb-4"><%= t(".preview", count: @locked_files) %></div>
        <% end %>

        <% if @model.respond_to?(:scan_started_at) && @model.scan_started_at.present? && !@model.scan_stale? %>
          <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-info/10 text-info dark:bg-info/20 dark:text-info mb-4"><%= t(".scan_in_progress") %></div>
        <% end %>

        <%= card(:secondary) do %>
          <p class="text-secondary-700 dark:text-secondary-300" itemprop="description"><%= markdownify @model.notes %></p>
        <% end if @model.notes.present? %>

        <div class="flex flex-wrap items-center gap-3 mb-6" role="toolbar" aria-label="Model actions">
          <%= render "models/show_list_actions" %>
          <%= DownloadButton(model: @model) %>
          <% if policy(@model).edit? %>
            <%= link_to Icon(icon: "pencil", label: translate("general.edit")), edit_model_path(@model), class: secondary_action_class, aria: {label: translate("components.model_card.edit_button.label", name: @model.name)} %>
          <% end %>
          <% if policy(@model).destroy? %>
            <%= link_to Icon(icon: "trash", label: translate("general.delete")), model_path(@model), method: :delete, data: {confirm: t("models.destroy.confirm")}, class: secondary_action_class(visibility: "hidden lg:inline-flex"), aria: {label: translate("components.model_card.delete_button.label", name: @model.name)} %>
          <% end %>
          <% if policy(@model).scan? %>
            <%= link_to Icon(icon: "radar", label: t(".rescan")), scan_model_path(@model), method: :post, class: secondary_action_class(visibility: "hidden lg:inline-flex") %>
          <% end %>
          <% if SiteSettings.multiuser_enabled? %>
            <%= link_to Icon(icon: "flag", label: translate("general.report", type: "")), new_model_report_path(@model), class: secondary_action_class(visibility: "hidden lg:inline-flex") %>
          <% end %>
          <% if policy(@model).edit? %>
            <%= link_to Icon(icon: "pencil", label: t(".files_card.bulk_edit")), bulk_edit_model_model_files_path(@model), class: secondary_action_class(visibility: "hidden lg:inline-flex") %>
          <% end %>
          <div class="lg:hidden relative" data-controller="dropdown">
            <button type="button" class="<%= secondary_action_class %> min-w-[44px] min-h-[44px]" data-action="click->dropdown#toggle" aria-expanded="false" aria-haspopup="menu" aria-label="<%= t("general.menu") %>">
              <%= Icon(icon: "list", label: t("general.menu")) %>
            </button>
            <ul class="absolute right-0 mt-1 min-w-[10rem] py-1 bg-white dark:bg-secondary-800 rounded-lg shadow-lg border border-secondary-200 dark:border-secondary-600 z-50 list-none m-0 p-0" data-dropdown-target="menu" role="menu">
              <%= DropdownItem(icon: "radar", label: t(".rescan"), path: scan_model_path(@model), method: :post) if policy(@model).scan? %>
              <%= DropdownItem(icon: "flag", label: translate("general.report", type: ""), path: new_model_report_path(@model)) if SiteSettings.multiuser_enabled? %>
              <%= DropdownItem(icon: "pencil", label: t(".files_card.bulk_edit"), path: bulk_edit_model_model_files_path(@model)) if policy(@model).edit? %>
              <%= DropdownItem(icon: "trash", label: translate("general.delete"), path: model_path(@model), method: :delete, confirm: t("models.destroy.confirm")) if policy(@model).destroy? %>
            </ul>
          </div>
        </div>

        <% if @num_files > 0 %>
          <% if policy(@model).edit? %>
            <div data-controller="file-list-selection" data-file-list-selection-model-id-value="<%= @model.public_id %>">
              <div data-file-list-selection-target="toolbar" hidden role="toolbar" aria-label="<%= t(".file_selection.toolbar_label") %>" class="fixed top-14 left-0 right-0 z-30 py-2 px-4 sm:px-6 lg:px-8 bg-white/95 dark:bg-secondary-900/95 backdrop-blur-sm border-b border-secondary-200 dark:border-secondary-700 shadow-sm dark:shadow-md">
                <div class="max-w-screen-2xl mx-auto flex flex-wrap items-center gap-2">
                  <%= form_with url: bulk_edit_selected_model_model_files_path(@model), method: :post, local: true, data: {turbo: false, file_list_selection_target: "bulkEditForm", action: "submit->file-list-selection#clearOnSubmit"}, class: "inline" do %>
                    <div data-file-list-selection-target="bulkEditIdsContainer"></div>
                    <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg bg-secondary-600 text-white hover:bg-secondary-700 dark:bg-secondary-500 dark:text-white dark:hover:bg-secondary-400 focus-visible:ring-2 focus-visible:ring-secondary-500 mr-2"><%= t(".file_selection.bulk_edit") %></button>
                  <% end %>
                  <%= form_with url: split_model_model_files_path(@model), method: :post, local: true, data: {turbo: false, file_list_selection_target: "splitForm", action: "submit->file-list-selection#clearOnSubmit"}, class: "inline" do %>
                    <div data-file-list-selection-target="splitIdsContainer"></div>
                    <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg border border-secondary-300 dark:border-secondary-500 text-secondary-800 dark:text-secondary-100 bg-white dark:bg-secondary-800 hover:bg-secondary-100 dark:hover:bg-secondary-700 focus-visible:ring-2 focus-visible:ring-secondary-500 mr-2"><%= t(".file_selection.split_out") %></button>
                  <% end %>
                  <button type="button" data-file-list-selection-target="clearButton" data-action="click->file-list-selection#clear" class="inline-flex items-center px-3 py-1.5 text-sm rounded-lg border border-secondary-300 dark:border-secondary-500 text-secondary-800 dark:text-secondary-100 bg-white dark:bg-secondary-800 hover:bg-secondary-100 dark:hover:bg-secondary-700 focus-visible:ring-2 focus-visible:ring-secondary-500"><%= t(".file_selection.clear") %></button>
                </div>
              </div>
              <h2 class="<%= heading_classes(:section) %> mb-4"><a name="files"><%= t(".files") %></a></h2>
              <div class="grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-4 mb-4" role="list">
                <%= render partial: "file", collection: @groups.delete(nil) %>
              </div>
              <% @groups.each_pair do |group, files| %>
                <h3 class="<%= heading_classes(:subsection) %> mb-3"><a name="<%= group.parameterize %>"><%= group.strip.careful_titleize %>*</a></h3>
                <div class="grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-4 mb-4" role="list">
                  <%= render partial: "file", collection: files %>
                </div>
              <% end %>
            </div>
          <% else %>
            <h2 class="<%= heading_classes(:section) %> mb-4"><a name="files"><%= t(".files") %></a></h2>
            <div class="grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-4 mb-4" role="list">
              <%= render partial: "file", collection: @groups.delete(nil) %>
            </div>
            <% @groups.each_pair do |group, files| %>
              <h3 class="<%= heading_classes(:subsection) %> mb-3"><a name="<%= group.parameterize %>"><%= group.strip.careful_titleize %>*</a></h3>
              <div class="grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-4 mb-4" role="list">
                <%= render partial: "file", collection: files %>
              </div>
            <% end %>
          <% end %>
        <% end %>

        <% if policy(:problem).show? %>
          <% if !@model.parents.empty? && policy(@model).merge? %>
            <%= card :danger, t(".merge.heading") do %>
              <p class="mb-2">
                <%= t(".merge.warning") %>
              </p>
              <strong><%= t(".merge.with") %>:</strong>
              <% @model.parents.each do |parent| %>
                <%= DoButton(icon: "union", label: parent.name, href: merge_models_path(target: parent.public_id, models: [@model.public_id]), method: :post, variant: "danger") %>
              <% end %>
            <% end %>
          <% end %>

          <% merge_histories = @model.merge_histories.active.order(created_at: :desc) %>
          <% if merge_histories.any? && policy(@model).unmerge? %>
            <% unmerge_days = (Model::UNMERGE_WINDOW / 1.day).to_i %>
            <%= card :warning, t(".merge_history.heading") do %>
              <p><small><%= t(".merge_history.window_notice", days: unmerge_days) %></small></p>
              <ul class="list-none pl-0 m-0">
                <% merge_histories.each do |h| %>
                  <li class="mb-4">
                    <div><strong><%= h.source_name %></strong></div>
                    <div><small><code class="text-xs"><%= h.source_path %></code></small></div>
                    <div class="text-end">
                      <% if h.created_at >= Model::UNMERGE_WINDOW.ago %>
                        <%= DoButton(icon: "arrow-counterclockwise", label: t(".merge_history.undo_button"), href: unmerge_model_path(@model, merge_history_id: h.id), method: :post, variant: "warning", confirm: t("general.are_you_sure")) %>
                      <% else %>
                        <button type="button" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg bg-warning/20 text-warning cursor-not-allowed opacity-75" disabled><%= t(".merge_history.undo_button") %></button>
                      <% end %>
                    </div>
                  </li>
                <% end %>
              </ul>
            <% end %>
          <% end %>

          <%= render "application/problems_card", problematic: @model, problems: @model.problems.visible(problem_settings), show_when_empty: true, card_id: "model-problems-card", card_data: tour_attributes(id: "model-problems-card", title: translate("models.show.problems_card.tour.title"), description: translate("models.show.problems_card.tour.description")), from_model: @model, nesting_models: (@model.contained_models if @model.contains_other_models?) %>
        <% end %>

        <%= card :secondary, t(".files_card.heading") do %>
          <a href="#files" class="no-underline hover:underline text-primary-600 dark:text-primary-400">Top</a>
          <ul class="list-none pl-0 mt-2">
            <% @groups.each_pair do |group, files| %>
              <li class="mt-1"><a href="#<%= group.parameterize %>" class="no-underline hover:underline text-primary-600 dark:text-primary-400"><%= group.strip.careful_titleize %>*</a></li>
            <% end %>
          </ul>
        <% end %>

        <% if policy(@model).upload? %>
          <%= card :secondary, t(".upload_card.heading") do %>
            <%= form_with url: model_model_files_path(@model), id: "upload-form", class: "grid" do |form| %>

              <%= content_tag :div, nil, class: "mb-4", data: {
                    controller: "upload",
                    action: "turbo:morph@window->upload#reconnect",
                    max_file_size: SiteSettings.max_file_upload_size,
                    allowed_file_types: input_accept_string,
                    upload_endpoint: upload_path
                  } %>
              <%= submit_tag translate(".submit"), class: "block w-full inline-flex justify-center items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <aside class="space-y-4 sticky top-16 self-start" id="sidebar">
        <%= card :secondary, t(".model_details") do %>
        <div class="grid grid-cols-[min-content_1fr] gap-x-4 gap-y-3 items-baseline">
          <%= AccessIndicator(object: @model, text: false) %>
          <%= AccessIndicator(object: @model, text: true, icon: false) %>
          <% if @model.creator %>
            <div class="flex items-center gap-2 text-secondary-700 dark:text-secondary-200"><%= Icon icon: "person", label: Creator.model_name.human %></div>
            <div class="min-w-0"><%= link_to @model.creator.name, @model.creator, itemprop: "author", class: content_link_class %></div>
          <% end %>
          <% if @model.collection %>
            <div class="flex items-center gap-2 text-secondary-700 dark:text-secondary-200"><%= Icon icon: "collection", label: Collection.model_name.human(count: 100) %></div>
            <div class="min-w-0"><%= link_to @model.collection.name, models_path({collection: @model.collection}.merge(@filter&.to_params)), class: content_link_class %></div>
          <% end %>
          <% if SiteSettings.show_libraries || current_user&.is_administrator? %>
            <div class="flex items-center gap-2 text-secondary-700 dark:text-secondary-200"><%= Icon icon: "boxes", label: Library.model_name.human %></div>
            <div class="min-w-0"><%= link_to @model.library.name, models_path({library: @model.library}.merge(@filter&.to_params)), class: content_link_class %></div>
          <% end %>
          <% if @model.license %>
            <div class="flex items-center gap-2 text-secondary-700 dark:text-secondary-200"><%= Icon icon: "card-heading", label: t(".license") %></div>
            <div class="min-w-0">
              <%= Spdx.licenses[@model.license]&.fetch("reference") ?
                link_to(t_license(@model.license), Spdx.licenses[@model.license]["reference"], itemprop: "license", class: content_link_class) :
                t_license(@model.license) %>
            </div>
          <% end %>
          <% if @model.sensitive %>
            <div class="flex items-center gap-2 text-secondary-700 dark:text-secondary-200"><%= Icon(icon: "explicit", label: Model.human_attribute_name(:sensitive)) %></div>
            <div class="min-w-0">
              <%= Model.human_attribute_name(:sensitive) %>
            </div>
          <% end %>
          <% if current_user&.is_administrator? %>
            <div class="flex items-center gap-2 text-secondary-700 dark:text-secondary-200"><%= Icon icon: "folder", label: t(".path") %></div>
            <div class="min-w-0">
              <%= content_tag(:code, class: "path") { safe_join @model.path.split("/"), safe_join([tag.wbr, "/"]) } %>
            </div>
          <% end %>
          <div class="flex items-center gap-2 text-secondary-700 dark:text-secondary-200"><%= Icon icon: "tag", label: t(".tags") %></div>
          <div class="min-w-0"><%= render "tag_list", tags: @model.tags.order(taggings_count: :desc, name: :asc), filter: @filter %></div>
          <% unless @model.links.empty? %>
            <div class="flex items-center gap-2 text-secondary-700 dark:text-secondary-200"><%= Icon icon: "link-45deg", role: "presentation", label: Model.human_attribute_name(:links) %></div>
            <div class="min-w-0"><%= LinkList links: @model.links, icons: false %></div>
          <% end %>
          <% if SiteSettings.social_enabled? %>
            <% if SiteSettings.federation_enabled? %>
              <div class="flex items-center gap-2 text-secondary-700 dark:text-secondary-200"><%= Icon icon: "at", label: t(".fediverse") %></div>
              <div class="min-w-0">
                <% if @model.remote? %>
                  <small><%= link_to @model.federails_actor.at_address, @model.federails_actor.profile_url, target: "new", class: content_link_class %></small>
                <% else %>
                  <small>
                    <%= CopyableText(text: @model.federails_actor.at_address, label: t("general.copy_fediverse_handle")) %>
                  </small>
                <% end %>
              </div>
            <% end %>
            <div class="flex items-center gap-2 text-secondary-700 dark:text-secondary-200"><%= Icon icon: "people", label: t(".followers") %></div>
            <div class="min-w-0">
              <%= t("general.followers", count: @model.followers.count) %>
              <div class="mt-1">
                <%= FollowButton(follower: current_user, target: @model) %>
              </div>
            </div>
          <% end %>
        </div>
        <% end %>
      </aside>
    </div>
  </article>
</div>
