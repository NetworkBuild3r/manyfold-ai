<% content_for :items do %>
  <% if @models.empty? %>
    <div class="tw:flex tw:flex-col tw:items-center tw:justify-center tw:py-12 tw:px-4 tw:text-center tw:rounded-xl tw:bg-surface-alt tw:dark:bg-secondary-800/50 tw:border tw:border-secondary-200 tw:dark:border-secondary-600" role="status" aria-live="polite">
      <%= Icon icon: "person-arms-up", label: "" %>
      <p class="tw:mt-4 tw:text-secondary-700 tw:dark:text-secondary-300"><%= signed_in? ? t(".no_results_html") : t(".no_results_signed_out_html", link: new_user_session_path) %></p>
      <% if @filter.any? %>
        <p class="tw:mt-2"><%= link_to t(".clear_filters"), models_path, class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus:tw:ring-2 focus:tw:ring-primary-500" %></p>
      <% end %>
      <% if @search %>
        <p class="tw:mt-4 tw:text-sm tw:text-secondary-600 tw:dark:text-secondary-400"><%= t ".search.or_other_sites" %></p>
        <div class="tw:mt-2"><%= render "search_links" %></div>
      <% end %>
    </div>
  <% else %>
    <div data-controller="model-list-selection" class="skip-link-container">
      <div data-model-list-selection-target="toolbar" hidden class="tw:flex tw:flex-wrap tw:items-center tw:gap-2 tw:mb-4">
        <%= link_to t(".selection.edit"), "#", data: {model_list_selection_target: "editLink", base_href: edit_model_path("__ID__")}, class: "tw:inline-flex tw:items-center tw:px-3 tw:py-1.5 tw:text-sm tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus:tw:ring-2 focus:tw:ring-primary-500" %>
        <% if policy(:model).bulk_edit? %>
          <%= form_with url: bulk_edit_selected_models_path, method: :post, data: {model_list_selection_target: "bulkEditForm", action: "submit->model-list-selection#clearOnSubmit"}, class: "tw:inline" do %>
            <div data-model-list-selection-target="idsContainer"></div>
            <button type="submit" class="tw:inline-flex tw:items-center tw:px-3 tw:py-1.5 tw:text-sm tw:rounded-lg tw:bg-secondary-600 tw:text-white hover:tw:bg-secondary-700 focus:tw:ring-2 focus:tw:ring-secondary-500 tw:mr-2"><%= t(".selection.bulk_edit") %></button>
          <% end %>
        <% end %>
        <button type="button" data-model-list-selection-target="clearButton" data-action="click->model-list-selection#clear" class="tw:inline-flex tw:items-center tw:px-3 tw:py-1.5 tw:text-sm tw:rounded-lg tw:border tw:border-secondary-300 tw:dark:border-secondary-500 tw:bg-transparent hover:tw:bg-secondary-100 tw:dark:hover:bg-secondary-700 focus:tw:ring-2 focus:tw:ring-secondary-500"><%= t(".selection.clear") %></button>
      </div>
      <div class="tw:flex tw:flex-wrap tw:items-center tw:gap-2 tw:mb-4">
        <%= skip_link "sidebar", t(".skip_models") %>
        <div class="tw:ml-auto">
          <%= SortMenu(filter: @filter) %>
        </div>
      </div>
      <% if @filter.any? %>
        <div class="tw:flex tw:flex-wrap tw:gap-2 tw:mb-4" role="group" aria-label="Active filters">
          <% active_filters_list(@filter).each do |entry| %>
            <span class="tw:inline-flex tw:items-center tw:gap-1 tw:px-3 tw:py-1.5 tw:rounded-full tw:bg-secondary-200 tw:dark:bg-secondary-600 tw:text-sm">
              <span class="tw:truncate tw:max-w-[200px]"><%= entry[:pill_label] %></span>
              <%= link_to "×", entry[:remove_url], class: "tw:flex-shrink-0 tw:rounded-full tw:p-0.5 hover:tw:bg-secondary-300 tw:dark:hover:bg-secondary-500 focus:tw:ring-2 focus:tw:ring-primary-500 focus:tw:outline-none", aria: { label: entry[:aria_remove] } %>
            </span>
          <% end %>
        </div>
      <% end %>
      <div class="tw:grid tw:grid-cols-[repeat(auto-fill,minmax(240px,1fr))] tw:gap-4 tw:mb-4 tw:[content-visibility:auto]" id="model-card-grid" role="list" aria-label="Models">
        <%= render_component_collection Components::ModelCard, :model, @models %>
        <% if @models.next_page %>
          <%= turbo_frame_tag "models_page_#{@models.next_page}", src: models_page_url(@models.next_page, @filter), loading: :lazy %>
        <% end %>
      </div>
      <% if @search %>
        <div class="tw:flex tw:items-center tw:gap-2 tw:mt-4 tw:py-3 tw:px-4 tw:rounded-lg tw:bg-secondary-100 tw:dark:bg-secondary-800 tw:text-secondary-700 tw:dark:text-secondary-300">
          <%= Icon icon: "search", label: "" %>
          <span><%= t ".search.other_sites" %></span>
          <%= render "search_links" %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>

<% content_for :actions do %>
  <%= link_to t(".bulk_edit"), edit_models_path((@additional_filters || {}).merge(@filter&.to_params)), class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:rounded-lg tw:bg-secondary-600 tw:text-white hover:tw:bg-secondary-700 focus:tw:ring-2 focus:tw:ring-secondary-500" if policy(:model).edit? %>
<% end %>

<% content_for :sidebar do %>
  <%= render "filters_card" %>
  <%= render "tags_card" %>
<% end %>
