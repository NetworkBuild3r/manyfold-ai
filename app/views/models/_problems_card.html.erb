<% model = local_assigns[:model] || @model %>
<%= card("secondary", Problem.model_name.human(count: 100), id: "model-problems-card", data: tour_attributes(id: "model-problems-card", title: translate(".tour.title"), description: translate(".tour.description"))) do %>
  <% if problems.empty? %>
    <p class="tw:text-secondary-500 tw:dark:tw:text-secondary-400 tw:mb-0"><%= t("problems.index.no_problems") %></p>
  <% else %>
  <% problems.each do |problem| %>
    <div class="tw:mb-4" id="problem-<%= problem.id %>">
      <details>
        <summary class="tw:cursor-pointer tw:font-medium">
          <%= problem_icon_tag(problem) %>
          <%= t("problems.model.%{cat}.title" % {cat: problem.category}) %>
        </summary>
        <div class="tw:rounded-lg tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:bg-white tw:dark:tw:bg-secondary-800/50 tw:p-4 tw:mb-2">
          <p>
            <%= t("problems.model.%{cat}.description_html" % {cat: problem.category}, note: problem.note) %>
          </p>
          <% if problem.category == "nesting" && model.contains_other_models? %>
            <ul class="tw:list-disc tw:pl-5 tw:my-2">
              <% model.contained_models.each do |target| %>
                <li><%= link_to target.name, model_path(target) %></li>
              <% end %>
            </ul>
            <p>
              <%= t("problems.model.nesting.warning") %>
            </p>
          <% end %>
          <div class="tw:text-end"><%= ResolveButton(problem: problem, user: current_user, from_model: model) %></div>
        </div>
      </details>
    </div>
  <% end %>
  <% end %>
<% end %>
