<%# Lazy-loaded library/creator/collection selects for the models filter form. %>
<%
  select_class = "block w-full max-w-full min-w-0 rounded-lg border border-secondary-300 dark:border-secondary-600 dark:bg-secondary-800 dark:text-secondary-100 px-3 py-2 text-sm shadow-sm focus:ring-2 focus:ring-primary-500"
  label_class = "block text-sm font-medium text-secondary-700 dark:text-secondary-300 mb-1"
%>
<%= turbo_frame_tag "model-filter-facets" do %>
  <div class="space-y-3">
    <% if @filter_libraries.present? && @filter_libraries.many? %>
      <div>
        <label for="filter_library" class="<%= label_class %>"><%= Library.model_name.human %></label>
        <select name="library" id="filter_library" class="<%= select_class %>">
          <option value="all" <%= "selected" unless @filter&.filtering_by?(:library) %>><%= t("models.model_filters_card.any", default: "Any") %></option>
          <% @filter_libraries.each do |lib| %>
            <option value="<%= lib.to_param %>" <%= "selected" if @filter&.parameter(:library).to_s == lib.to_param %>><%= lib.name %></option>
          <% end %>
        </select>
      </div>
    <% end %>

    <div>
      <label for="filter_creator" class="<%= label_class %>"><%= Creator.model_name.human %></label>
      <select name="creator" id="filter_creator" class="<%= select_class %>">
        <option value="all" <%= "selected" if @filter&.parameter(:creator).blank? %>><%= t("models.model_filters_card.any", default: "Any") %></option>
        <option value="" <%= "selected" if @filter&.parameter(:creator) == "" %>><%= t("models.model_filters_card.none", default: "None (unassigned)") %></option>
        <% (@filter_creators || []).each do |creator| %>
          <option value="<%= creator.to_param %>" <%= "selected" if @filter&.parameter(:creator).to_s == creator.to_param %>><%= creator.name.careful_titleize %></option>
        <% end %>
      </select>
    </div>

    <div>
      <label for="filter_collection" class="<%= label_class %>"><%= Collection.model_name.human %></label>
      <select name="collection" id="filter_collection" class="<%= select_class %>">
        <option value="all" <%= "selected" if @filter&.parameter(:collection).blank? %>><%= t("models.model_filters_card.any", default: "Any") %></option>
        <option value="" <%= "selected" if @filter&.parameter(:collection) == "" %>><%= t("models.model_filters_card.none", default: "None (unassigned)") %></option>
        <% (@filter_collections || []).each do |collection| %>
          <option value="<%= collection.to_param %>" <%= "selected" if @filter&.parameter(:collection).to_s == collection.to_param %>><%= collection.name %></option>
        <% end %>
      </select>
    </div>
  </div>
<% end %>
