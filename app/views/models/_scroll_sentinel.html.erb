<%# Thin wrapper — prefer application/browse_scroll_sentinel directly. %>
<%= render "application/browse_scroll_sentinel",
      sentinel_id: local_assigns.fetch(:sentinel_id, "models-scroll-sentinel"),
      position: local_assigns.fetch(:position, :bottom),
      meta: local_assigns.fetch(:meta, {
        next_url: local_assigns.fetch(:next_url, ""),
        prev_url: local_assigns.fetch(:prev_url, ""),
        has_more_after: local_assigns.fetch(:next_url, "").present?,
        has_more_before: local_assigns.fetch(:prev_url, "").present?,
        total_count: local_assigns.fetch(:total_count, 0),
        offset: local_assigns.fetch(:offset, 0)
      }),
      loading_label: local_assigns.fetch(:loading_label, t("models.list.loading_more")) %>
