<%= PageTitle title: @entry.name, breadcrumbs: {
      Model.model_name.human(count: 100) => models_path,
      @model.name => model_path(@model),
      @file.name => model_model_file_path(@model, @file)
    } %>

<div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6">
  <div class="min-w-0">
    <% if @entry.is_image? && @entry.preview_exists? %>
      <%= image_tag preview_model_model_file_archive_entry_path(@model, @file, @entry),
            alt: @entry.name,
            class: "w-full h-auto rounded-xl border border-secondary-200 dark:border-secondary-700" %>
    <% elsif @entry.is_renderable? %>
      <%= Renderer(
            preview_url: content_model_model_file_archive_entry_path(@model, @file, @entry),
            format: @entry.extension,
            size: @entry.size,
            canvas_id: "preview-entry-#{@entry.to_param}"
          ) %>
    <% elsif @entry.preview_exists? %>
      <%= image_tag preview_model_model_file_archive_entry_path(@model, @file, @entry),
            alt: @entry.name,
            class: "w-full h-auto rounded-xl" %>
    <% else %>
      <div class="rounded-xl border border-secondary-200 dark:border-secondary-700 p-12 text-center text-secondary-500">
        <%= t("archive_entries.show.no_preview", default: "No preview available for this entry.") %>
      </div>
    <% end %>
  </div>

  <div class="min-w-0 space-y-4">
    <%= card :secondary, t("archive_entries.show.details", default: "Entry details") do %>
      <div class="grid grid-cols-[min-content_1fr] gap-x-4 gap-y-2 items-baseline text-sm">
        <span class="text-secondary-600 dark:text-secondary-400"><%= t("archive_entries.show.path", default: "Path") %></span>
        <code class="break-all"><%= @entry.pathname %></code>
        <span class="text-secondary-600 dark:text-secondary-400"><%= t("archive_entries.show.kind", default: "Kind") %></span>
        <span><%= @entry.kind %></span>
        <% if @entry.size %>
          <span class="text-secondary-600 dark:text-secondary-400"><%= t("archive_entries.show.size", default: "Size") %></span>
          <span><%= number_to_human_size @entry.size, precision: 2 %></span>
        <% end %>
        <span class="text-secondary-600 dark:text-secondary-400"><%= t("archive_entries.show.status", default: "Status") %></span>
        <span><%= @entry.status.humanize %></span>
      </div>
      <div class="mt-4">
        <%= link_to t("archive_entries.panel.download", default: "Download"),
              download_model_model_file_archive_entry_path(@model, @file, @entry),
              class: "inline-flex items-center px-3 py-2 text-sm font-medium rounded-lg bg-primary-600 text-white hover:bg-primary-700 no-underline" %>
      </div>
    <% end %>
  </div>
</div>
