<%= cocooned_item class: "tw:flex tw:flex-wrap tw:items-center tw:gap-2 tw:mb-2" do %>
  <%- if f.object.persisted? %>
    <span class="tw:shrink-0">
      <%- case f.object.subject.class.name %>
      <%- when "User" %>
        <%= Icon icon: "person", label: f.object.subject.class.model_name.human %>
        <%= f.object.subject.username %>
        <%= t(".subject.you") if f.object.subject == current_user %>
      <%- when "Role" %>
        <%= Icon icon: "people", label: "" %>
        <%= t(".subject.role.%{name}" % {name: f.object.subject&.name}) %>
      <%- when "Group" %>
        <%= Icon icon: "people", label: "" %>
        <%= f.object.subject&.name %>
      <%- when "NilClass" %>
        <%= Icon icon: "globe", label: "" %>
        <%= t(".subject.role.public") %>
      <%- else %>
        what
      <%- end %>
    </span>
  <%- else %>
    <%= f.text_field :subject, class: "tw:block tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800 tw:shrink-0", placeholder: translate(".subject.placeholder"), list: "caber-relations-role-list" %>
  <%- end %>
  <%= f.select :permission, Caber.configuration.permissions.map { |p| [translate(".permissions.%{perm}" % {perm: p}), p] }, {}, {class: "tw:block tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800 tw:shrink-0", disabled: (f.object.subject == current_user)} %>
  <%= cocooned_remove_item_button Icon(icon: "trash", label: translate(".delete")), f, class: "tw:inline-flex tw:items-center tw:px-3 tw:py-2 tw:rounded-lg tw:border tw:border-danger tw:text-danger hover:tw:bg-danger/10 tw:shrink-0" unless f.object.subject == current_user %>
<% end %>
