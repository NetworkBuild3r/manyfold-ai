<%= cocooned_item class: "flex flex-wrap items-center gap-2 mb-2" do %>
  <%- if f.object.persisted? %>
    <span class="shrink-0">
      <%- case f.object.subject.class.name %>
      <%- when "User" %>
        <%= Icon icon: "person", label: f.object.subject.class.model_name.human %>
        <%= f.object.subject.username %>
        <%= t(".subject.you") if f.object.subject == current_user %>
      <%- when "Role" %>
        <%= Icon icon: "people", label: "" %>
        <%= t(".subject.role.%{name}" % {name: f.object.subject&.name}) %>
      <%- when "Group" %>
        <%= Icon icon: "people", label: "" %>
        <%= f.object.subject&.name %>
      <%- when "NilClass" %>
        <%= Icon icon: "globe", label: "" %>
        <%= t(".subject.role.public") %>
      <%- else %>
        what
      <%- end %>
    </span>
  <%- else %>
    <%= f.text_field :subject, class: "block rounded-lg border border-secondary-300 px-3 py-2 shadow-sm focus:ring-2 focus:ring-primary-500 dark:border-secondary-600 dark:bg-secondary-800 shrink-0", placeholder: translate(".subject.placeholder"), list: "caber-relations-role-list" %>
  <%- end %>
  <%= f.select :permission, Caber.configuration.permissions.map { |p| [translate(".permissions.%{perm}" % {perm: p}), p] }, {}, {class: "block rounded-lg border border-secondary-300 px-3 py-2 shadow-sm focus:ring-2 focus:ring-primary-500 dark:border-secondary-600 dark:bg-secondary-800 shrink-0", disabled: (f.object.subject == current_user)} %>
  <%= cocooned_remove_item_button Icon(icon: "trash", label: translate(".delete")), f, class: "inline-flex items-center px-3 py-2 rounded-lg border border-danger text-danger hover:bg-danger/10 shrink-0" unless f.object.subject == current_user %>
<% end %>
