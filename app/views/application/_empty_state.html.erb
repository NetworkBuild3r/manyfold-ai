<%# Renders a centered empty state. Locals: message (required), icon (default: "inbox"), extra_class (optional). Optional block for additional content (e.g. clear filters link). %>
<div class="flex flex-col items-center justify-center py-12 px-4 text-center rounded-xl bg-surface-alt dark:bg-secondary-800/50 border border-secondary-200 dark:border-secondary-600 <%= local_assigns[:extra_class] %>" role="status" aria-live="polite">
  <%= Icon icon: local_assigns[:icon] || "inbox", label: "" %>
  <p class="mt-4 text-secondary-700 dark:text-secondary-300"><%= message %></p>
  <% if block_given? %>
    <div class="mt-2"><%= yield %></div>
  <% end %>
</div>
