<%# Archive contents panel — list entries, previews, scan / download actions. %>
<%
  file = local_assigns.fetch(:file)
  page_size = ArchiveEntriesController::PAGE_SIZE
  entries_scope = file.archive_entries.order(:pathname)
  total = entries_scope.count
  entries = entries_scope.limit(page_size).to_a
  pending = file.archive_entries.where(status: %w[listed preview_pending]).count
  ready = file.archive_entries.where(status: "preview_ready").count
  failed = file.archive_entries.where(status: "preview_failed").count
  grid_id = "archive-entries-grid-#{file.to_param}"
  load_more_id = "archive-entries-load-more-#{file.to_param}"
  next_offset = entries.size
  has_more = next_offset < total
%>
<%= card :secondary, t("archive_entries.panel.title") do %>
  <div class="flex flex-wrap items-center gap-2 mb-3">
    <% if policy(file).scan_archive? %>
      <%= button_to t("archive_entries.panel.scan"),
            scan_archive_model_model_file_path(file.model, file),
            method: :post,
            class: "inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
    <% end %>
    <% if total.positive? %>
      <p class="text-sm text-secondary-600 dark:text-secondary-400">
        <%= t("archive_entries.panel.counts",
              total: total,
              ready: ready,
              pending: pending,
              failed: failed) %>
        <% if file.archive_entries_truncated? %>
          <span class="text-warning"> · <%= t("archive_entries.panel.truncated") %></span>
        <% end %>
      </p>
    <% else %>
      <p class="text-sm text-secondary-600 dark:text-secondary-400">
        <%= t("archive_entries.panel.empty") %>
      </p>
    <% end %>
  </div>

  <% if entries.any? %>
    <div id="<%= grid_id %>" class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <% entries.each do |entry| %>
        <%= render Components::ArchiveEntryCard.new(entry: entry, file: file) %>
      <% end %>
    </div>
    <div id="<%= load_more_id %>" class="mt-3">
      <%= render "application/archive_entries_load_more",
            file: file,
            next_offset: next_offset,
            has_more: has_more,
            per_page: page_size %>
    </div>
  <% end %>
<% end %>
