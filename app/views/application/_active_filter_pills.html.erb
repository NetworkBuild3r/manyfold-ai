<%# Shared active-filter pill rail (models / creators / collections browse chrome). %>
<%
  filter = local_assigns.fetch(:filter)
  clear_path = local_assigns.fetch(:clear_path)
  clear_label = local_assigns.fetch(:clear_label, t("models.list.clear_filters"))
  aria_label = local_assigns.fetch(:aria_label, t("models.list.active_filters"))
  entries = active_filters_list(filter)
%>
<% if entries.any? %>
  <div class="flex gap-2 overflow-x-auto pb-0.5 -mx-1 px-1 scrollbar-thin" role="group" aria-label="<%= aria_label %>">
    <% entries.each do |entry| %>
      <span class="inline-flex items-center gap-1.5 shrink-0 px-3 py-1.5 rounded-full bg-primary-100 dark:bg-primary-900/40 text-primary-900 dark:text-primary-100 text-sm border border-primary-200/80 dark:border-primary-800">
        <span class="truncate max-w-[14rem]"><%= entry[:pill_label] %></span>
        <%= link_to "×", entry[:remove_url], class: "flex-shrink-0 rounded-full p-0.5 hover:bg-primary-200 dark:hover:bg-primary-800 focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:outline-none no-underline", aria: {label: entry[:aria_remove]} %>
      </span>
    <% end %>
    <%= link_to clear_label, clear_path, class: "inline-flex items-center shrink-0 px-3 py-1.5 rounded-full text-sm text-secondary-600 dark:text-secondary-400 hover:text-primary-700 dark:hover:text-primary-300 no-underline" %>
  </div>
<% end %>
