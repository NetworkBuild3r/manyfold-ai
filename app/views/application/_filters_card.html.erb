<% if @filter.any? %>
  <%= card :secondary, t(".title") do %>
    <% active_filters_list(@filter).each do |entry| %>
      <div class="flex items-center gap-2 py-2 border-b border-secondary-200 dark:border-secondary-500 last:border-0 text-secondary-900 dark:text-secondary-100">
        <span class="flex-shrink-0" aria-hidden="true"><%= Icon icon: entry[:icon], label: entry[:type_label] %></span>
        <div class="min-w-0 flex-1" aria-label="<%= entry[:type_label] %>">
          <% if entry[:key] == :tag %>
            <span class="pe-none"><%= render "tag_list", tags: @filter.tags, filter: @filter %></span>
          <% else %>
            <%= entry[:value_html] %>
          <% end %>
        </div>
        <span class="flex-shrink-0"><%= link_to Icon(icon: "trash", label: entry[:aria_remove]), entry[:remove_url], class: "text-danger hover:underline focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:outline-none", aria: {label: entry[:aria_remove]} %></span>
      </div>
    <% end %>
  <% end %>
<% end %>
