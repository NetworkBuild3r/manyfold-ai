<div>
  <%= form.label :links %>
</div>
<div>
  <%= cocooned_container id: "cocooned-links", data: {controller: "cocooned"} do %>
    <%= form.fields_for :links do |f| %>
      <%= render "link_fields", f: f %>
    <% end %>
  <% end %>
  <div>
    <%= cocooned_add_item_button t(".add"), form, :links,
          class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-lg border border-secondary-300 bg-white dark:border-secondary-600 dark:bg-secondary-800 text-secondary-700 dark:text-secondary-200 hover:bg-secondary-50 hover:dark:bg-secondary-700",
          insertion_node: "#cocooned-links",
          insertion_method: "append" %>
  </div>
</div>
