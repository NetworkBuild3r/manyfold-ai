<div>
  <%= form.label :links %>
</div>
<div>
  <%= cocooned_container id: "cocooned-links", data: {controller: "cocooned"} do %>
    <%= form.fields_for :links do |f| %>
      <%= render "link_fields", f: f %>
    <% end %>
  <% end %>
  <div>
    <%= cocooned_add_item_button t(".add"), form, :links,
          class: "tw:inline-flex tw:items-center tw:gap-1.5 tw:px-3 tw:py-1.5 tw:text-sm tw:font-medium tw:rounded-lg tw:border tw:border-secondary-300 tw:bg-white tw:dark:border-secondary-600 tw:dark:bg-secondary-800 tw:text-secondary-700 tw:dark:text-secondary-200 hover:tw:bg-secondary-50 hover:tw:dark:bg-secondary-700",
          insertion_node: "#cocooned-links",
          insertion_method: "append" %>
  </div>
</div>
