<%# Infinite-scroll sentinel (top or bottom) for bidirectional row window.
    Client owns fetch URLs; sentinels expose flags/totals/offset only. %>
<%
  sentinel_id = local_assigns.fetch(:sentinel_id)
  position = local_assigns.fetch(:position, :bottom) # :top or :bottom
  meta = local_assigns.fetch(:meta, {})
  has_more_after = ActiveModel::Type::Boolean.new.cast(meta.fetch(:has_more_after, false))
  has_more_before = ActiveModel::Type::Boolean.new.cast(meta.fetch(:has_more_before, false))
  total_count = meta.fetch(:total_count, 0).to_i
  offset = meta.fetch(:offset, 0).to_i
  loading_label = local_assigns.fetch(:loading_label, t("models.list.loading_more"))
  target = (position == :top) ? "topSentinel" : "sentinel"
  # Top sentinel is an insertion/observe point only — never shows a loader.
  show_loader = (position == :bottom && has_more_after)
%>
<div id="<%= sentinel_id %>"
     class="browse-scroll-sentinel browse-scroll-sentinel--<%= position %> col-span-full<%= " browse-scroll-sentinel--end" unless show_loader %>"
     data-infinite-scroll-target="<%= target %>"
     data-has-more-after="<%= has_more_after %>"
     data-has-more-before="<%= has_more_before %>"
     data-total-count="<%= total_count %>"
     data-offset="<%= offset %>"
     <%= "hidden" if position == :bottom && !show_loader %>
     aria-hidden="true">
  <% if show_loader %>
    <span class="browse-scroll-sentinel__label"><%= loading_label %></span>
  <% end %>
</div>
