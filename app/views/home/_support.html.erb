<div class="tw:rounded-xl tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:bg-white tw:dark:tw:bg-secondary-800 tw:shadow-sm tw:overflow-hidden">
  <h2 class="tw:px-4 tw:py-3 tw:bg-secondary-600 tw:text-white tw:m-0 tw:font-medium tw:flex tw:items-center tw:gap-2">
    <%= Icon icon: "piggy-bank" %>
    <%= t ".title" %>
  </h2>

  <div class="tw:p-4">
    <% if SiteSettings.support_link.presence %>
      <div class="tw:mb-4">
        <p><%= t ".content" %></p>
        <div class="tw:text-right">
          <%= GoButton(label: t(".support_link"), href: SiteSettings.support_link, variant: :primary, icon: "box-arrow-up-right", target: "_manyfold_support") %>
        </div>
      </div>
      <hr class="tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:my-4">
    <% end %>
    <p><%= t ".manyfold_html" %></p>
    <div class="tw:text-right tw:mt-2">
      <%= GoButton(label: t(".support_manyfold"), href: "https://opencollective.com/manyfold", variant: :primary, icon: "box-arrow-up-right", target: "_manyfold_donate") %>
    </div>
  </div>

</div>
