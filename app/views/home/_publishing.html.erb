<div class="tw:rounded-xl tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:bg-white tw:dark:tw:bg-secondary-800 tw:shadow-sm tw:overflow-hidden">
  <h2 class="tw:px-4 tw:py-3 tw:bg-secondary-600 tw:text-white tw:m-0 tw:font-medium tw:flex tw:items-center tw:gap-2">
    <%= Icon icon: "send" %>
    <%= t ".title" %>
  </h2>

  <div class="tw:p-4">
    <p>
      <%= t ".content" %>
    </p>
    <%- if current_user.creators.empty? %>
      <p>
        <%= t ".new_creator.content" %>
      </p>
      <div class="tw:text-right tw:mt-2">
        <%= GoButton(label: t(".new_creator.button"), href: new_creator_path, variant: :primary, icon: "box-arrow-up-right", target: "_manyfold_new_creator") %>
      </div>
    <%- else %>
      <p>
        <%= t ".existing_creator.content" %>
      </p>
      <div class="tw:text-right tw:mt-2">
        <%= GoButton(label: t(".existing_creator.button"), href: edit_creator_path(current_user.creators.local.first), variant: :primary, icon: "box-arrow-up-right", target: "_manyfold_edit_creator") %>
      </div>
    <%- end %>
  </div>

</div>
