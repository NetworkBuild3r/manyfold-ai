          <%= link_to t("settings.integrations.heading"), integrations_settings_path, class: current_page?(integrations_settings_path) ? "tw:block tw:px-3 tw:py-2 tw:text-sm tw:rounded-lg tw:bg-primary-100 tw:text-primary-700 tw:dark:bg-primary-900/40 tw:dark:text-primary-200 tw:font-medium" : "tw:block tw:px-3 tw:py-2 tw:text-sm tw:text-secondary-700 tw:dark:text-secondary-300 tw:rounded-lg tw:no-underline hover:tw:bg-secondary-100 tw:dark:hover:bg-secondary-800", aria: (current_page?(integrations_settings_path) ? { current: "page" } : {}) %>
