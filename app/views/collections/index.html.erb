<% content_for :page_header do %>
  <%= PageTitle title: Collection.model_name.human(count: 100), heading: false %>
<% end %>

<% content_for :browse_chrome do %>
  <div class="flex flex-col gap-2.5 max-w-screen-2xl mx-auto">
    <div class="flex flex-wrap items-center gap-2 sm:gap-3">
      <button type="button"
              class="lg:hidden inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-lg border border-secondary-300 dark:border-secondary-600 bg-surface dark:bg-secondary-900 text-secondary-900 dark:text-secondary-100 hover:border-primary-400 focus-visible:ring-2 focus-visible:ring-primary-500"
              data-action="click->filter-drawer#open"
              aria-controls="sidebar"
              aria-expanded="false">
        <%= Icon icon: "funnel", label: "" %>
        <span><%= t("layouts.card_list_page.filters_heading", default: "Filters") %></span>
        <% if @filter&.any? %>
          <span class="inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1 rounded-full bg-primary-600 text-white text-xs font-semibold"><%= active_filters_list(@filter).size %></span>
        <% end %>
      </button>
      <div class="flex items-center gap-2 ml-auto">
        <%= SortMenu(filter: @filter) %>
      </div>
    </div>
    <%= render "application/active_filter_pills", filter: @filter, clear_path: collections_path, clear_label: t(".clear_filters") if @filter&.any? %>
  </div>
<% end %>

<% content_for :items do %>
  <% if @collections.empty? && (@unassigned_count || 0) == 0 %>
    <%= render "application/empty_state", message: t(".no_results_html"), icon: "collection" do %>
      <% if @filter&.any? %>
        <p><%= link_to t(".clear_filters"), collections_path, class: primary_button_class %></p>
      <% end %>
    <% end %>
  <% else %>
    <div class="skip-link-container">
      <%= skip_link "sidebar", t(".skip_collections") %>
      <% cols = @browse_columns || browse_grid_columns %>
      <% per_page = @browse_per_page || browse_grid_page_size %>
      <% next_url = @collections.next_page ? collections_page_url(@collections.next_page, @filter, per_page: per_page) : "" %>
      <% show_unassigned = @unassigned_count.to_i > 0 && @collections.first_page? && !(@filter&.filtering_by?(:collection) || @filter&.filtering_by?(:creator)) %>
      <div data-controller="infinite-scroll"
           data-infinite-scroll-next-url-value="<%= next_url %>"
           data-infinite-scroll-per-page-value="<%= per_page %>"
           data-infinite-scroll-sentinel-id-value="collections-scroll-sentinel"
           data-infinite-scroll-card-selector-value=".collection-card"
           data-infinite-scroll-storage-key-prefix-value="scroll_collections_"
           data-infinite-scroll-end-message-value="<%= t(".end_of_results") %>"
           class="library-infinite">
        <div class="browse-card-grid gap-3 sm:gap-3.5 mb-2"
             id="collection-card-grid"
             style="--browse-cols: <%= cols %>"
             role="list"
             aria-label="<%= Collection.model_name.human(count: 100) %>"
             data-browse-columns="<%= cols %>"
             data-infinite-scroll-target="grid">
          <%= render "unassigned" if show_unassigned %>
          <%= render @collections %>
          <%= render "application/browse_scroll_sentinel",
                sentinel_id: "collections-scroll-sentinel",
                next_url: next_url,
                loading_label: t(".loading_more") %>
        </div>
        <div class="library-infinite__end py-10 text-center">
          <p id="collections-scroll-status"
             class="browse-scroll-status"
             data-infinite-scroll-target="status"
             role="status"
             aria-live="polite"
             hidden></p>
          <p class="mt-2 text-sm text-secondary-500 dark:text-secondary-400 library-infinite__hint">
            <%= t(".scroll_hint") %>
          </p>
        </div>
        <button type="button"
                class="models-back-to-top"
                data-infinite-scroll-target="backToTop"
                hidden
                aria-label="<%= t(".back_to_top") %>">
          <i class="bi bi-arrow-up" aria-hidden="true"></i>
          <span><%= t(".back_to_top") %></span>
        </button>
      </div>
    </div>
  <% end %>
<% end %>

<% content_for :actions do %>
  <%= link_to t("collections.general.new"), new_collection_path, class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" if policy(:collection).new? %>
<% end %>

<% content_for :sidebar do %>
  <%= render "filters_card" %>
  <%= render "tags_card" %>
<% end %>
