<%= form_with model: @application, class: "container-md tabular-form" do |form| %>
  <%= text_input_row form, :name, autofocus: true %>
  <%= text_input_row form, :redirect_uri, help: t(".redirect_uri.help") %>
  <%= select_input_row form, :scopes,
        ["public", "read", "write", "delete"],
        label: t(".scopes.label"),
        multiple: true %>
  <%= checkbox_input_row form, :confidential, help: t(".confidential.help") %>
  <div>
    <%= form.submit translate(".submit"), class: "tw:inline-flex tw:items-center tw:gap-1.5 tw:px-3 tw:py-1.5 tw:text-sm tw:font-medium tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500" %>
  </div>
<% end %>
