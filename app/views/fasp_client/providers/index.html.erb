<h3><%= t(".heading") %></h3>

<p class="tw:text-lg tw:text-secondary-600 tw:dark:tw:text-secondary-400">
  <%= t(".description_html") %>
</p>
<p>
  <%= t(".add_html", base_url: fasp_client_url) %>
</p>

<% if @providers.none? { |it| it.base_url == "https://search.3dprint.social/fasp"} %>
  <div class="tw:px-4 tw:py-3 tw:rounded-lg tw:bg-info/10 tw:text-info tw:mb-4">
    <%= t(".search_3dprint_social_html") %>
  </div>
<% end %>

<% if @providers.any? %>
  <h4><%= t(".provider_list_title") %></h4>
<% end %>
<div class="tw:grid tw:grid-cols-1 tw:md:grid-cols-2 tw:gap-6">
  <% @providers.find_each do |provider| %>
    <div class="tw:rounded-xl tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:bg-white tw:dark:tw:bg-secondary-800 tw:shadow-sm tw:overflow-hidden">
      <div class="tw:px-4 tw:py-3 tw:bg-secondary-600 tw:text-white tw:font-medium">
        <%= provider.name %>
      </div>
      <div class="tw:p-4">
        <div class="tw:mb-3 tw:text-right">
          <%= GoButton(icon: "pencil", label: t("general.edit"), href: edit_provider_path(provider), variant: :secondary) %>
        </div>
        <table class="tw:w-full tw:border-collapse">
          <tbody>
            <tr class="tw:border-b tw:border-secondary-200 tw:dark:tw:border-secondary-600">
              <td class="tw:px-0 tw:py-2 tw:font-medium tw:align-top"><%= t(".url") %></td>
              <td class="tw:px-0 tw:py-2 tw:pl-4"><%= link_to provider.base_url, provider.base_url, rel: "noopener", class: "tw:text-primary-600 tw:dark:tw:text-primary-400 hover:tw:underline" %></td>
            </tr>
            <tr class="tw:border-b tw:border-secondary-200 tw:dark:tw:border-secondary-600">
              <td class="tw:px-0 tw:py-2 tw:font-medium"><%= t(".registered_at") %></td>
              <td class="tw:px-0 tw:py-2 tw:pl-4"><%= provider.created_at %></td>
            </tr>
            <tr>
              <td class="tw:px-0 tw:py-2 tw:font-medium"><%= t(".status") %></td>
              <td class="tw:px-0 tw:py-2 tw:pl-4"><%= provider.status %></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
