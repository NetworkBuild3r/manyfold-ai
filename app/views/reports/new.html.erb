<h3 class="<%= heading_classes(:section) %> mb-2"><%= t(".title", type: @reportable.model_name.human, name: @reportable.name) %></h3>

<p class="text-lg text-secondary-600 dark:text-secondary-400"><%= t ".description" %></p>

<%= form_with model: [@reportable, @report], class: "tabular-form" do |form| %>

  <%= text_input_row form, :content %>

  <div>
    <%= form.submit translate(".submit"), class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
  </div>

<% end %>
