<% if f.object.user.nil? || f.object&.user&.active? == true %>
  <%= cocooned_item class: "tw:mb-2 tw:flex tw:gap-2" do %>
    <%= f.text_field :user_id,
          class: "tw:block tw:flex-1 tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm focus:tw:ring-2 focus:tw:ring-primary-500 tw:dark:border-secondary-600 tw:dark:bg-secondary-800",
          placeholder: translate(".user_id.placeholder"),
          value: f.object&.user&.username,
          disabled: f.object.persisted? %>
    <%= cocooned_remove_item_button Icon(icon: "trash", label: translate(".user_id.delete")), f, class: "tw:inline-flex tw:items-center tw:gap-1.5 tw:px-3 tw:py-1.5 tw:text-sm tw:font-medium tw:rounded-lg tw:border tw:border-danger tw:text-danger tw:bg-transparent hover:tw:bg-danger/10 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500" %>
  <% end %>
<% end %>
