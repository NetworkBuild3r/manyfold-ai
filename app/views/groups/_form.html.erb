<p><%= t(".intro") %></p>

<%= form_with model: [creator, group], class: "max-w-2xl mx-auto px-4 tabular-form" do |form| %>
  <%= TextInputRow(form: form, attribute: :name, label: Group.human_attribute_name(:name), help: t(".name.help")) %>
  <%= RichTextInputRow(form: form, attribute: :description, label: Group.human_attribute_name(:description), help: t(".description.help")) %>

  <div>
    <%= form.label :memberships %>
  </div>
  <div>
    <%= cocooned_container id: "cocooned-memberships", data: {controller: "cocooned"} do
          form.fields_for :memberships do |f|
            render "membership_fields", f: f
          end
        end %>
    <%= cocooned_add_item_button t(".add"), form, :memberships,
          class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-lg border border-secondary-300 bg-white dark:border-secondary-600 dark:bg-secondary-800 text-secondary-700 dark:text-secondary-200 hover:bg-secondary-50 hover:dark:bg-secondary-700",
          insertion_node: "#cocooned-memberships",
          insertion_method: "append" %>
  </div>

  <div class="flex flex-wrap items-center gap-2">
    <%= form.submit class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
    <% if group.persisted? && policy(group).destroy? %>
      <%= link_to creator_group_path(creator, group), {
            method: :delete,
            class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-lg border border-danger text-danger bg-transparent hover:bg-danger/10 ms-auto",
            data: {confirm: translate("views.groups.form.confirm_destroy")}
          } do %>
        <%= Icon(icon: "trash", label: t("general.delete")) %>
        <%= t("general.delete") %>
      <% end %>
    <% end %>
  </div>
<% end %>
