<h3 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100 mb-2"><%= t(".title") %></h3>

<%= form_with model: [:settings, @domain_block], class: "tabular-form" do |form| %>

  <%= text_input_row form, :domain %>

  <div>
    <%= form.submit translate(".submit"), class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
  </div>

<% end %>
