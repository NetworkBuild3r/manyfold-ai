<h3 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100 mb-2"><%= t(".title") %></h3>

<p class="text-lg text-secondary-600 dark:text-secondary-400"><%= t(".description") %></p>

<table class="w-full border-collapse border border-secondary-200 dark:border-secondary-600">
  <thead>
    <tr class="border-b border-secondary-200 dark:border-secondary-600 bg-secondary-50 dark:bg-secondary-800/50">
      <th class="px-4 py-2 text-left"><%= Federails::Moderation::DomainBlock.human_attribute_name(:domain) %></th>
      <th class="px-4 py-2 text-left"><%= Federails::Moderation::DomainBlock.human_attribute_name(:created_at) %></th>
      <th class="px-4 py-2 text-left"></th>
    </tr>
  </thead>
  <tbody>
  <% @blocks.each do |block| %>
    <tr class="border-b border-secondary-200 dark:border-secondary-600 even:bg-secondary-50 dark:even:bg-secondary-800/30">
      <td class="px-4 py-2"><%= block.domain %></td>
      <td class="px-4 py-2"><%= block.created_at %></td>
      <td class="px-4 py-2 text-right"><%= link_to safe_join([Icon(icon: "trash", label: t("general.delete")), t("general.delete")], " "), settings_domain_block_path(block), {method: :delete, class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-danger text-danger hover:bg-danger/10 no-underline", data: {confirm: translate(".confirm_destroy")}} if policy(block).destroy? %></td>
    </tr>
  <% end %>
  </tbody>
</table>

<%= link_to t(".new"), new_settings_domain_block_path, class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500 no-underline mt-4" if policy(Federails::Moderation::DomainBlock).new? %>
