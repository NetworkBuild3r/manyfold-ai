<h3 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100 mb-2"><%= t(".title") %></h3>

<div class="flex flex-wrap items-center justify-between gap-2 mb-4">
  <p class="text-lg text-secondary-600 dark:text-secondary-400 mb-0"><%= t(".description") %></p>
  <%= link_to t(".new"), new_settings_user_path, class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500 no-underline" if policy(:user).new? %>
</div>

<%= paginate @users %>

<table class="w-full border-collapse border border-secondary-200 dark:border-secondary-600">
  <thead>
    <tr class="border-b border-secondary-200 dark:border-secondary-600 bg-secondary-50 dark:bg-secondary-800/50 [&_th]:px-4 [&_th]:py-2 [&_th]:text-left [&_th]:font-medium">
      <%= ColumnHeader label: User.human_attribute_name(:approved), sort_param: :order, sort_option: "pending", sort_default: true if SiteSettings.approve_signups %>
      <%= ColumnHeader label: User.human_attribute_name(:username), sort_param: :order, sort_option: "name" %>
      <%= ColumnHeader label: User.human_attribute_name(:email) %>
      <%= ColumnHeader label: User.human_attribute_name(:auth_uid) if SiteSettings.oidc_enabled? %>
      <%= ColumnHeader label: t(".local") if SiteSettings.federation_enabled? %>
      <%= ColumnHeader label: t(".fediverse_address") if SiteSettings.federation_enabled? %>
      <%= ColumnHeader label: User.human_attribute_name(:created_at), sort_param: :order, sort_option: "recent" %>
      <%= ColumnHeader label: User.human_attribute_name(:roles) %>
      <th class="px-4 py-2 text-left"></th>
    </tr>
  </thead>
  <tbody>
  <% @users.each do |user| %>
    <tr class="border-b border-secondary-200 dark:border-secondary-600 even:bg-secondary-50 dark:even:bg-secondary-800/30 <%= user.approved? ? "" : "bg-info/10 dark:bg-info/20" %>">
      <td class="px-4 py-2">
        <%= Icon(icon: "hourglass", label: "") unless user.approved? %>
        <%= "âœ…" if user.approved? %>
      </td>
      <td class="px-4 py-2">
        <%= user.username %>
      </td>
      <td class="px-4 py-2"><%= masked_email(user.email) %></td>
      <%= content_tag :td, (user.auth_uid ? "âœ…" : "âŒ"), class: "px-4 py-2" if SiteSettings.oidc_enabled? %>
      <%= content_tag :td, (user.local? ? "âœ…" : "âŒ"), class: "px-4 py-2" if SiteSettings.federation_enabled? %>
      <%= content_tag :td, user.federails_actor&.at_address, class: "px-4 py-2" if SiteSettings.federation_enabled? %>
      <%= content_tag :td, user.created_at, class: "px-4 py-2" %>
      <td class="px-4 py-2"><%= user.roles&.map(&:name)&.join(", ") %></td>
      <td class="px-4 py-2"><%= link_to safe_join([Icon(icon: "search", label: t(".view")), t(".view")], " "), settings_user_path(user), class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border border-secondary-300 bg-white dark:border-secondary-600 dark:bg-secondary-800 text-secondary-700 hover:bg-secondary-50 dark:hover:bg-secondary-700 no-underline text-sm" %></td>
    </tr>
  <% end %>
  </tbody>
</table>

<%= paginate @users %>
