<%= form_with model: [:settings, user], class: "tabular-form" do |form| %>

  <%= text_input_row form, :username %>
  <%= text_input_row form, :email %>

  <% if !user.persisted? %>
    <% if SiteSettings.email_configured? %>
      <div></div>
      <div class="tw:px-4 tw:py-3 tw:rounded-lg tw:bg-info/10 tw:text-info">
        <%= t(".password_reset_help") %>
      </div>
    <% else %>
      <%= password_input_row form, :password %>
      <%= password_input_row form, :password_confirmation %>
    <% end %>
  <% end %>

  <div>
    <%= form.label :roles, class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
  </div>
  <div class="tw:flex tw:flex-wrap tw:gap-4 tw:items-center">
    <%= form.collection_check_boxes :role_ids, @available_roles, :id, :name do |b| # rubocop:disable Pundit/UsePolicyScope
          content_tag :div, class: "tw:flex tw:items-center tw:gap-2" do
            b.check_box(class: "tw:rounded tw:border-secondary-300 tw:text-primary-600 tw:focus:ring-primary-500 tw:h-4 tw:w-4") +
              b.label(class: "tw:text-sm tw:text-secondary-700 tw:dark:tw:text-secondary-300 tw:cursor-pointer")
          end
        end %>
  </div>

  <% if SiteSettings.enable_user_quota %>
    <h3><%= t("settings.users.quota.title") %></h3>
    <%= checkbox_input_row form, :quota_use_site_default, label: t("settings.users.quota.using_site_default") %>
    <%= numeric_input_row form, :quota,
          label: t("settings.users.quota.current_quota"),
          min: 0, step: 1,
          unit: "MB",
          value: (user.quota.to_i / 1.megabyte) %>
  <% end %>

  <div>
    <%= form.submit translate(".submit"), class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500" %>
  </div>

<% end %>
