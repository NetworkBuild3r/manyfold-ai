<h3><%= Federails::Moderation::Report.model_name.human %> #<%= @report.id %></h3>

<ul>
  <li>
    <%= Federails::Moderation::Report.human_attribute_name(:created_at) %>:
    <%= @report.created_at %>
  </li>
  <li>
    <%= Federails::Moderation::Report.human_attribute_name(:federails_actor) %>:
    <%= @report.reporter_address %>
  </li>
</ul>

<% if @report.content.present? %>
  <h4><%= Federails::Moderation::Report.human_attribute_name(:content) %>:</h4>
  <div class="tw:px-4 tw:py-3 tw:rounded-lg tw:bg-warning/10 tw:text-warning">
    <%= @report.content %>
  </div>
<% end %>

<h4><%= Federails::Moderation::Report.human_attribute_name(:object) %></h4>
<table class="tw:w-full tw:border-collapse tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600">
  <tbody>
  <% Array(@report.object).each do |object| %>
    <tr class="tw:border-b tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:even:tw:bg-secondary-50 tw:dark:tw:even:tw:bg-secondary-800/30">
      <% if @report.object&.entity %>
        <td class="tw:px-4 tw:py-2">
          <%= @report.object.entity.model_name.human %>
        </td>
        <td class="tw:px-4 tw:py-2">
          <%= link_to @report.object.entity.name, @report.object.entity, class: "tw:text-primary-600 tw:dark:tw:text-primary-400 hover:tw:underline" %>
        </td>
      <% end %>
    </tr>
  <% end %>
  </tbody>
</table>

<div class="tw:flex tw:flex-wrap tw:gap-2 tw:mt-4">
  <%= link_to t(".resolve"), settings_report_path(@report, resolve: true), method: :patch, class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500 tw:no-underline" %>
  <%= link_to t(".ignore"), settings_report_path(@report, ignore: true), method: :patch, class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:rounded-lg tw:bg-danger tw:text-white hover:tw:opacity-90 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500 tw:no-underline" %>
</div>
