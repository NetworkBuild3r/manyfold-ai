<h3 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100 mb-2"><%= Federails::Moderation::Report.model_name.human %> #<%= @report.id %></h3>

<ul>
  <li>
    <%= Federails::Moderation::Report.human_attribute_name(:created_at) %>:
    <%= @report.created_at %>
  </li>
  <li>
    <%= Federails::Moderation::Report.human_attribute_name(:federails_actor) %>:
    <%= @report.reporter_address %>
  </li>
</ul>

<% if @report.content.present? %>
  <h4 class="text-lg font-medium text-secondary-900 dark:text-secondary-100 mt-4 mb-2"><%= Federails::Moderation::Report.human_attribute_name(:content) %>:</h4>
  <div class="px-4 py-3 rounded-lg bg-warning/10 text-warning dark:bg-warning/20">
    <%= @report.content %>
  </div>
<% end %>

<h4 class="text-lg font-medium text-secondary-900 dark:text-secondary-100 mt-4 mb-2"><%= Federails::Moderation::Report.human_attribute_name(:object) %></h4>
<table class="w-full border-collapse border border-secondary-200 dark:border-secondary-600">
  <tbody>
  <% Array(@report.object).each do |object| %>
    <tr class="border-b border-secondary-200 dark:border-secondary-600 even:bg-secondary-50 dark:even:bg-secondary-800/30">
      <% if @report.object&.entity %>
        <td class="px-4 py-2">
          <%= @report.object.entity.model_name.human %>
        </td>
        <td class="px-4 py-2">
          <%= link_to @report.object.entity.name, @report.object.entity, class: "text-primary-600 dark:text-primary-400 hover:underline" %>
        </td>
      <% end %>
    </tr>
  <% end %>
  </tbody>
</table>

<div class="flex flex-wrap gap-2 mt-4">
  <%= link_to t(".resolve"), settings_report_path(@report, resolve: true), method: :patch, class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500 no-underline" %>
  <%= link_to t(".ignore"), settings_report_path(@report, ignore: true), method: :patch, class: "inline-flex items-center px-4 py-2 rounded-lg bg-danger text-white hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary-500 no-underline" %>
</div>
