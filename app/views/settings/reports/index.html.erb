<h3 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100 mb-2"><%= t(".title") %></h3>

<p class="text-lg text-secondary-600 dark:text-secondary-400"><%= t(".description") %></p>

<table class="w-full border-collapse border border-secondary-200 dark:border-secondary-600">
  <thead>
    <tr class="border-b border-secondary-200 dark:border-secondary-600 bg-secondary-50 dark:bg-secondary-800/50">
      <th colspan="2" class="px-4 py-2 text-left"><%= Federails::Moderation::Report.human_attribute_name(:object) %></th>
      <th colspan="2" class="px-4 py-2 text-left"><%= Federails::Moderation::Report.human_attribute_name(:federails_actor) %></th>
      <th class="px-4 py-2 text-left"><%= Federails::Moderation::Report.human_attribute_name(:created_at) %></th>
      <th class="px-4 py-2 text-left"></th>
    </tr>
  </thead>
  <tbody>
  <% @reports.each do |report|
    next unless report.object %>
    <tr class="border-b border-secondary-200 dark:border-secondary-600 even:bg-secondary-50 dark:even:bg-secondary-800/30">
      <td class="px-4 py-2"><%= Icon icon: icon_for(report.object.entity.class), label: "" %></td>
      <td class="px-4 py-2"><%= link_to report.object.entity.name, report.object.entity, class: "text-primary-600 dark:text-primary-400 hover:underline" if report.object&.entity %></td>
      <td class="px-4 py-2">
        <%= Icon icon: report.local? ? "house" : "globe", label: "" %>
      </td>
      <td class="px-4 py-2"><%= report.reporter_address %></td>
      <td class="px-4 py-2"><%= report.created_at %></td>
      <td class="px-4 py-2 text-right"><%= link_to safe_join([Icon(icon: "search", label: t("general.view")), t("general.view")], " "), settings_report_path(report), {class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 no-underline"} %></td>
    </tr>
  <% end %>
  </tbody>
</table>
