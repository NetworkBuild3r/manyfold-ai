<%= PageTitle title: Problem.model_name.human(count: 100) %>

<%= render "filters" %>

<% if @counts_by_category.present? %>
  <div class="flex flex-wrap gap-2 mb-4">
    <% @counts_by_category.sort_by { |cat, _| cat.to_s }.each do |cat, count| %>
      <% active = params[:category].to_a.include?(cat.to_s) %>
      <%= link_to "#{t("problems.categories.%{cat}" % {cat: cat})} (#{count})", problems_path(request.query_parameters.merge(category: [cat])), class: "inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-sm no-underline focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:outline-none #{active ? 'bg-primary-600 text-white dark:bg-primary-500 dark:text-white' : 'bg-secondary-200 dark:bg-secondary-600 text-secondary-800 dark:text-secondary-100 hover:bg-secondary-300 dark:hover:bg-secondary-500'}" %>
    <% end %>
  </div>
<% end %>

<%= paginate @problems %>

<% if @problems.empty? %>
  <%= render "application/empty_state", message: t(".no_problems"), icon: "check-circle" do %>
    <p><%= link_to Model.model_name.human(count: 100), models_path, class: "inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 no-underline" %></p>
  <% end %>
<% else %>
<div class="rounded-xl border border-secondary-200 dark:border-secondary-600 overflow-hidden bg-surface dark:bg-surface-dark">
<%= form_with url: resolve_problems_path(format: :turbo_stream), method: :post, class: "mb-0" do |form| %>
  <table class="w-full border-collapse border-0" data-controller="bulk-edit collapse" data-action="change->bulk-edit#handleCheckboxChange">
    <thead>
      <tr class="border-b border-secondary-200 dark:border-secondary-600 bg-secondary-50 dark:bg-secondary-800/50">
        <th class="px-4 py-2 text-left"><input type="checkbox" aria-label="<%= translate ".select_all" %>" value="0" name="bulk-select-all"></th>
        <th class="px-4 py-2 text-left" colspan=2><%= t(".item") %></th>
        <th class="px-4 py-2 text-left"><%= t(".description") %></th>
        <th class="px-4 py-2 text-left"><span id="resolve-heading"><%= t(".resolve") %></span></th>
        <th class="px-4 py-2 text-left"><%= t(".ignore") %></th>
      </tr>
    </thead>
    <tbody>
    <% @problems.each do |problem| %>
      <% next unless problem.problematic %>
      <tr id="problem-<%= problem.id %>" class="border-b border-secondary-200 dark:border-secondary-600 even:bg-secondary-50 dark:even:bg-secondary-800/30 show problem-severity-<%= problem_severity(problem) %> <%= problem.ignored && "opacity-50" %>" data-collapse-target="content">
        <td class="px-4 py-2"><%= form.check_box "problems[#{problem.to_param}]", data: {resolution_strategy: problem.resolution_strategy, bulk_item: problem.to_param}, "aria-label": translate(".select"), class: "rounded border-secondary-300 text-primary-600 focus:ring-primary-500 h-4 w-4" %></td>
        <% if problem.parent %>
          <td class="px-4 py-2"><%= link_to problem.parent.name, problem.parent, class: "text-primary-600 dark:text-primary-400 hover:underline" %></td>
          <% if problem.problematic.is_a? ModelFile %>
            <td class="px-4 py-2"><%= link_to problem.problematic.name, [problem.parent, problem.problematic], class: "text-primary-600 dark:text-primary-400 hover:underline" %></td>
          <% elsif problem.problematic.is_a? Link %>
            <td class="px-4 py-2"><%= link_to problem.problematic.url, problem.problematic.url, class: "text-primary-600 dark:text-primary-400 hover:underline" %></td>
          <% else %>
            <td class="px-4 py-2"></td>
          <% end %>
        <% else %>
          <td class="px-4 py-2" colspan=2><%= link_to problem.problematic.name, problem.problematic, class: "text-primary-600 dark:text-primary-400 hover:underline" %></td>
        <% end %>
        <td class="px-4 py-2">
          <%= t "problems.%{type}.%{category}.title" % {type: problem.problematic_type.underscore, category: problem.category} %>
          <% if problem.note %>
            <br>
            <small class="text-secondary-600 dark:text-secondary-400"><%= problem.note %></small>
          <% end %>
        </td>
        <td class="px-4 py-2"><%= ResolveButton(problem: problem, user: current_user) %></td>
        <td class="px-4 py-2">
          <% if problem.ignored %>
            <%= link_to Icon(icon: "eye-fill", label: t(".unignore")), problem_path(problem, problem: {ignored: false}), method: :patch, class: "inline-flex items-center px-3 py-1.5 rounded-lg border border-secondary-300 dark:border-secondary-500 bg-white dark:bg-secondary-800 text-secondary-700 dark:text-secondary-100 hover:bg-secondary-50 dark:hover:bg-secondary-700 focus-visible:ring-2 focus-visible:ring-primary-500 no-underline text-sm" %>
          <% else %>
            <%= link_to Icon(icon: "eye-slash", label: t(".ignore")), problem_path(problem, problem: {ignored: true}), method: :patch, class: "inline-flex items-center px-3 py-1.5 rounded-lg border border-secondary-300 dark:border-secondary-500 bg-white dark:bg-secondary-800 text-secondary-700 dark:text-secondary-100 hover:bg-secondary-50 dark:hover:bg-secondary-700 focus-visible:ring-2 focus-visible:ring-primary-500 no-underline text-sm", data: {action: "click->collapse#hideContaining"} %>
          <% end %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>

  <div class="flex flex-wrap gap-2 p-4 border-t border-secondary-200 dark:border-secondary-600">
    <%= form.submit translate(".bulk_resolve"), name: "resolve", class: "inline-flex items-center px-4 py-2 rounded-lg bg-danger text-white hover:opacity-90 focus-visible:ring-2 focus-visible:ring-primary-500", data: {confirm: translate(".bulk_confirm")} %>
    <%= form.submit translate(".bulk_ignore"), name: "ignore", class: "inline-flex items-center px-4 py-2 rounded-lg border border-secondary-300 dark:border-secondary-500 bg-white dark:bg-secondary-800 text-secondary-700 dark:text-secondary-100 hover:bg-secondary-50 dark:hover:bg-secondary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
  </div>
<% end %>
</div>
<% end %>

<%= paginate @problems %>
