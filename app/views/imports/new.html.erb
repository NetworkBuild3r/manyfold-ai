<%= PageTitle title: t(".heading", site_name: site_name), heading: false %>

<div class="tw:max-w-4xl tw:mx-auto tw:px-4">
  <h1><%= t(".heading", site_name: site_name) %></h1>
  <% if @deserializer %>
    <p><%= t(".import_type_html", url: @url, object_type: @deserializer.capabilities[:class].model_name.human) %></p>

    <table class="tw:w-full tw:border-collapse tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:mb-4">
      <tbody>
      <% @deserializer.capabilities.except(:class).each_pair do |key, value| %>
        <tr class="tw:border-b tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:even:tw:bg-secondary-50 tw:dark:tw:even:tw:bg-secondary-800/30">
          <td class="tw:px-4 tw:py-2"><%= @deserializer.capabilities[:class].human_attribute_name(key) %></td>
          <td class="tw:px-4 tw:py-2"><%= value ? "✅" : "❌" %></td>
        </tr>
      <% end %>
      </tbody>
    </table>

    <%= DoButton icon: "download", label: t(".import"), href: imports_path(url: @url), method: :post, variant: "primary" %>
  <% else %>

    <div class="tw:grid tw:grid-cols-1 tw:md:grid-cols-[1fr_auto] tw:gap-6">
      <div>
        <p class="tw:text-lg tw:text-secondary-600 tw:dark:tw:text-secondary-400"><%= t(".description") %></p>
        <p><%= t(".import_capabilities") %></p>
        <%= form_with url: new_import_path, method: :get, class: "tw:mt-4" do |f| %>
          <div class="tw:flex tw:rounded-lg tw:overflow-hidden tw:border tw:border-secondary-300 tw:dark:tw:border-secondary-600 tw:mb-4">
            <%= f.url_field :url, class: "tw:flex-1 tw:block tw:w-full tw:rounded-none tw:border-0 tw:px-3 tw:py-2 tw:shadow-sm focus:tw:ring-2 focus:tw:ring-primary-500 tw:dark:tw:bg-secondary-800", placeholder: translate(".placeholder"), aria_label: translate(".submit"), value: @url %>
            <%= f.submit translate(".submit"), class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500", name: nil %>
          </div>
        <% end %>
      </div>
      <div class="tw:shrink-0">
        <div class="tw:rounded-xl tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:bg-white tw:dark:tw:bg-secondary-800 tw:shadow-sm tw:p-4">
          <h5 class="tw:text-lg tw:font-medium tw:mb-2"><%= t ".supported_sites" %></h5>
          <ul class="tw:list-none tw:pl-0 tw:space-y-1">
            <li><%= ((SiteSettings.cults3d_api_key.present? && SiteSettings.cults3d_api_username.present?) ? "✅" : "❌") %> <%= t "sites.cults3d" %></li>
            <li><%= (SiteSettings.myminifactory_api_key.present? ? "✅" : "❌") %> <%= t "sites.myminifactory" %></li>
            <li><%= (SiteSettings.thingiverse_api_key.present? ? "✅" : "❌") %> <%= t "sites.thingiverse" %></li>
          </ul>
          <%= link_to t(".integration_settings"), integrations_settings_path, class: "tw:text-primary-600 tw:dark:tw:text-primary-400 hover:tw:underline tw:mt-2 tw:inline-block" if policy(:settings).index? %>
        </div>
      </div>
    </div>

  <% end %>
</div>
