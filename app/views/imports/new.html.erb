<%= PageTitle title: t(".heading", site_name: site_name), heading: false %>

<div class="max-w-4xl mx-auto px-4">
  <h1 class="<%= heading_classes(:page) %> mb-4"><%= t(".heading", site_name: site_name) %></h1>
  <% if @deserializer %>
    <p><%= t(".import_type_html", url: @url, object_type: @deserializer.capabilities[:class].model_name.human) %></p>

    <table class="w-full border-collapse border border-secondary-200 dark:border-secondary-600 mb-4">
      <tbody>
      <% @deserializer.capabilities.except(:class).each_pair do |key, value| %>
        <tr class="border-b border-secondary-200 dark:border-secondary-600 even:bg-secondary-50 dark:even:bg-secondary-800/30">
          <td class="px-4 py-2"><%= @deserializer.capabilities[:class].human_attribute_name(key) %></td>
          <td class="px-4 py-2"><%= value ? "âœ…" : "âŒ" %></td>
        </tr>
      <% end %>
      </tbody>
    </table>

    <%= DoButton icon: "download", label: t(".import"), href: imports_path(url: @url), method: :post, variant: "primary" %>
  <% else %>

    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6">
      <div>
        <p class="text-lg text-secondary-600 dark:text-secondary-400"><%= t(".description") %></p>
        <p><%= t(".import_capabilities") %></p>
        <%= form_with url: new_import_path, method: :get, class: "mt-4" do |f| %>
          <div class="flex rounded-lg overflow-hidden border border-secondary-300 dark:border-secondary-600 mb-4">
            <%= f.url_field :url, class: "flex-1 block w-full rounded-none border-0 px-3 py-2 shadow-sm focus:ring-2 focus:ring-primary-500 dark:bg-secondary-800", placeholder: translate(".placeholder"), aria_label: translate(".submit"), value: @url %>
            <%= f.submit translate(".submit"), class: "inline-flex items-center px-4 py-2 bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500", name: nil %>
          </div>
        <% end %>
      </div>
      <div class="shrink-0">
        <div class="rounded-xl border border-secondary-200 dark:border-secondary-600 bg-surface dark:bg-surface-dark shadow-sm p-4">
          <h5 class="text-lg font-medium mb-2"><%= t ".supported_sites" %></h5>
          <ul class="list-none pl-0 space-y-1">
            <li><%= ((SiteSettings.cults3d_api_key.present? && SiteSettings.cults3d_api_username.present?) ? "âœ…" : "âŒ") %> <%= t "sites.cults3d" %></li>
            <li><%= (SiteSettings.myminifactory_api_key.present? ? "âœ…" : "âŒ") %> <%= t "sites.myminifactory" %></li>
            <li><%= (SiteSettings.thingiverse_api_key.present? ? "âœ…" : "âŒ") %> <%= t "sites.thingiverse" %></li>
          </ul>
          <%= link_to t(".integration_settings"), integrations_settings_path, class: "text-primary-600 dark:text-primary-400 hover:underline mt-2 inline-block" if policy(:settings).index? %>
        </div>
      </div>
    </div>

  <% end %>
</div>
