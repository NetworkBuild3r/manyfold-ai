<% content_for :head do %>
  <%= tag.meta property: "og:type", content: "profile" %>
  <%= tag.meta name: "description", content: truncate(sanitize(@creator.caption), length: 80) if @creator.caption.present? %>
  <%= tag.link rel: "alternate", type: Mime[:oembed], href: creator_url(@creator, format: :oembed), title: @creator.name %>
<% end %>

<%= content_for :page_header do %>
  <%= PageTitle title: @creator.name, heading: false, breadcrumbs: {
        Creator.model_name.human(count: 100) => creators_path
      } %>
<% end %>

<%= content_for :items do %>
  <%= turbo_stream_from @creator %>
  <div class="tw:rounded-xl tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:bg-white tw:dark:tw:bg-secondary-800 tw:shadow-sm tw:overflow-hidden tw:mb-4 <%= "remote-actor" if @creator.remote? %>">
    <%= content_tag :div, class: "tw:flex tw:flex-wrap tw:items-start tw:gap-4 tw:p-4 with-background", style: (@creator.banner ? "background-image: url(#{banner_creator_path(@creator)}); background-position: center; background-size: cover" : nil) do %>
      <% if @creator.avatar %>
        <div class="tw:shrink-0">
          <%= Avatar(url: avatar_creator_path(@creator), size: :large) if @creator.avatar %>
        </div>
      <% end %>
      <div class="tw:shrink-0">
        <%= content_tag(:div, class: "tw:text-center") do %>
          <h2 class="tw:text-xl tw:font-semibold tw:mb-2">
            <%= @creator.name %>
          </h2>
          <% if SiteSettings.federation_enabled? %>
            <p class="tw:mb-2">
              <% if @creator.remote? %>
                <small class="tw:text-secondary-600 tw:dark:tw:text-secondary-400"><%= link_to @creator.federails_actor.at_address, @creator.federails_actor.profile_url, target: "new", class: "tw:text-primary-600 tw:dark:tw:text-primary-400 hover:tw:underline" %></small>
              <% elsif SiteSettings.federation_enabled? %>
                <small class="tw:text-secondary-600 tw:dark:tw:text-secondary-400">
                  <%= CopyableText(text: @creator.federails_actor.at_address, label: t("general.copy_fediverse_handle")) %>
                </small>
              <% end %>
            </p>
          <% end %>
          <%= FollowButton(follower: current_user, target: @creator) %>
        <% end %>
      </div>
      <div class="tw:flex-1 tw:min-w-0">
        <%= content_tag(:p, class: "tw:text-lg tw:text-secondary-600 tw:dark:tw:text-secondary-400 tw:mb-2") { @creator.caption } if @creator.caption %>
        <% model_count = policy_scope(Model).where(creator: @creator).count %>
        <p class="tw:mb-1"><%= "#{model_count} #{Model.model_name.human count: model_count}" %></p>
        <%= content_tag(:p, class: "tw:mb-1") { t("general.followers", count: @creator.followers.count) } if SiteSettings.social_enabled? %>
        <p><%= AccessIndicator(object: @creator, text: true) %></p>
      </div>
      <div class="tw:shrink-0">
        <%= LinkList links: @creator.links %>
      </div>
    <% end %>
    <% if @creator.notes %>
      <hr class="tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:my-0">
      <%= content_tag :div, class: "tw:p-4 tw:prose tw:dark:tw:prose-invert tw:max-w-none" do %>
        <%= markdownify @creator.notes %>
      <% end %>
    <% end %>
  </div>
<% end %>

<% content_for :actions do %>
  <%= link_to safe_join([Icon(icon: "pencil", label: t(".edit")), t(".edit")], " "), edit_creator_path(@creator), class: "tw:inline-flex tw:items-center tw:gap-2 tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500 tw:no-underline" if policy(@creator).edit? %>
  <%= ReportButton(object: @creator, path: new_creator_report_path(@creator)) %>
  <%= GoButton(href: creator_groups_path(@creator), label: t("views.groups.index.title"), variant: :secondary) if policy(Group.new(creator: @creator)).index? %>
<% end %>

<%= render "models/list" %>
