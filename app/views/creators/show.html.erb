<% content_for :head do %>
  <%= tag.meta property: "og:type", content: "profile" %>
  <%= tag.meta name: "description", content: truncate(sanitize(@creator.caption), length: 80) if @creator.caption.present? %>
  <%= tag.link rel: "alternate", type: Mime[:oembed], href: creator_url(@creator, format: :oembed), title: @creator.name %>
<% end %>

<%= content_for :page_header do %>
  <%= PageTitle title: @creator.name, heading: false, breadcrumbs: {
        Creator.model_name.human(count: 100) => creators_path
      } %>
<% end %>

<%= content_for :items do %>
  <%= turbo_stream_from @creator %>
  <div class="rounded-xl border border-secondary-200 dark:border-secondary-600 bg-surface dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow overflow-hidden mb-4 <%= "remote-actor" if @creator.remote? %>">
    <%= content_tag :div, class: "flex flex-wrap items-start gap-4 p-4 with-background", style: (@creator.banner ? "background-image: url(#{banner_creator_path(@creator)}); background-position: center; background-size: cover" : nil) do %>
      <% if @creator.avatar %>
        <div class="shrink-0">
          <%= Avatar(url: avatar_creator_path(@creator), size: :large) if @creator.avatar %>
        </div>
      <% end %>
      <div class="shrink-0">
        <%= content_tag(:div, class: "text-center") do %>
          <h2 class="text-xl font-semibold text-secondary-900 dark:text-secondary-100 mb-2">
            <%= @creator.name %>
          </h2>
          <% if SiteSettings.federation_enabled? %>
            <p class="mb-2">
              <% if @creator.remote? %>
                <small class="text-secondary-600 dark:text-secondary-400"><%= link_to @creator.federails_actor.at_address, @creator.federails_actor.profile_url, target: "new", class: "text-primary-600 dark:text-primary-400 hover:underline" %></small>
              <% elsif SiteSettings.federation_enabled? %>
                <small class="text-secondary-600 dark:text-secondary-400">
                  <%= CopyableText(text: @creator.federails_actor.at_address, label: t("general.copy_fediverse_handle")) %>
                </small>
              <% end %>
            </p>
          <% end %>
          <%= FollowButton(follower: current_user, target: @creator) %>
        <% end %>
      </div>
      <div class="flex-1 min-w-0">
        <%= content_tag(:p, class: "text-lg text-secondary-600 dark:text-secondary-400 mb-2") { @creator.caption } if @creator.caption %>
        <% model_count = policy_scope(Model).where(creator: @creator).count %>
        <p class="mb-1"><%= "#{model_count} #{Model.model_name.human count: model_count}" %></p>
        <%= content_tag(:p, class: "mb-1") { t("general.followers", count: @creator.followers.count) } if SiteSettings.social_enabled? %>
        <p><%= AccessIndicator(object: @creator, text: true) %></p>
      </div>
      <div class="shrink-0">
        <%= LinkList links: @creator.links %>
      </div>
    <% end %>
    <% if @creator.notes %>
      <hr class="border-secondary-200 dark:border-secondary-600 my-0">
      <%= content_tag :div, class: "p-4 prose dark:prose-invert max-w-none" do %>
        <%= markdownify @creator.notes %>
      <% end %>
    <% end %>
  </div>
<% end %>

<% content_for :actions do %>
  <%= link_to safe_join([Icon(icon: "pencil", label: t(".edit")), t(".edit")], " "), edit_creator_path(@creator), class: "inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500 no-underline" if policy(@creator).edit? %>
  <%= ReportButton(object: @creator, path: new_creator_report_path(@creator)) %>
  <%= GoButton(href: creator_groups_path(@creator), label: t("views.groups.index.title"), variant: :secondary) if policy(Group.new(creator: @creator)).index? %>
<% end %>

<%= render "models/list" %>
