    <div class="p-4">
      <div class="font-medium text-secondary-900 dark:text-secondary-100"><%= t(".name") %></div>
      <span class="block mt-2 text-sm text-secondary-600 dark:text-secondary-400"><%= t(".caption") %></span>
    </div>
    <div class="px-4 py-3 border-t border-secondary-200 dark:border-secondary-600">
      <%= link_to "#{@unassigned_count} #{Model.model_name.human count: @unassigned_count}", models_path(creator: ""), class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
    </div>
  </div>
</div>
