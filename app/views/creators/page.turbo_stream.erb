<%= turbo_stream.before "creators-scroll-sentinel" do %>
  <% @creators.each do |creator| %>
    <%= render creator %>
  <% end %>
<% end %>

<%= turbo_stream.replace "creators-scroll-sentinel" do %>
  <%= render "application/browse_scroll_sentinel",
        sentinel_id: "creators-scroll-sentinel",
        next_url: (@creators.next_page ? creators_page_url(@creators.next_page, @filter, per_page: @browse_per_page) : ""),
        loading_label: t("creators.index.loading_more") %>
<% end %>
