<div class="tw:max-w-md tw:mx-auto tw:px-4">
  <%= PageTitle title: t("devise.registrations.new.sign_up") %>

  <% if SiteSettings.rules.presence %>
    <h2><%= t("devise.registrations.new.rules") %></h2>
    <div class="tw:px-4 tw:py-3 tw:rounded-lg tw:bg-warning/10 tw:text-warning tw:mb-4">
      <%= markdownify(SiteSettings.rules) %>
    </div>
    <p class="tw:mb-4">
      <%= t("devise.registrations.new.rules_agree") %>
    </p>
  <% end %>

  <h2><%= t("devise.registrations.new.details") %></h2>

  <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: {method: :put}) do |form| %>
    <div class="tabular-form tw:mb-4">
      <%= form.hidden_field :invitation_token, readonly: true %>

      <%= text_input_row form, :username, autocomplete: "username", help: t("devise.registrations.new.username.help"), value: nil, required: true %>

      <% if form.object.class.require_password_on_accepting %>
        <%= password_input_row form, :password, autocomplete: "new-password" %>
        <%= password_input_row form, :password_confirmation, autocomplete: "new-password" %>
      <% end %>

      <div class="tw:flex tw:flex-wrap tw:items-center tw:gap-2">
        <%= form.submit translate("devise.registrations.new.sign_up"), class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500" %>
        <div class="tw:ml-auto">
          <%= AltchaWidget() %>
        </div>
      </div>
    </div>
    <%= content_tag :div, t("devise.registrations.new.approval_help"), class: "tw:px-4 tw:py-3 tw:rounded-lg tw:bg-info/10 tw:text-info tw:mb-4" if SiteSettings.approve_signups %>
  <% end %>
</div>
