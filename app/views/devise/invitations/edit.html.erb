<div class="max-w-md mx-auto px-4">
  <%= PageTitle title: t("devise.registrations.new.sign_up") %>

  <% if SiteSettings.rules.presence %>
    <h2 class="<%= heading_classes(:section) %> mb-2"><%= t("devise.registrations.new.rules") %></h2>
    <div class="px-4 py-3 rounded-lg bg-warning/10 text-warning mb-4">
      <%= markdownify(SiteSettings.rules) %>
    </div>
    <p class="mb-4">
      <%= t("devise.registrations.new.rules_agree") %>
    </p>
  <% end %>

  <h2 class="<%= heading_classes(:page) %> mb-4"><%= t("devise.registrations.new.details") %></h2>

  <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: {method: :put}) do |form| %>
    <div class="tabular-form mb-4">
      <%= form.hidden_field :invitation_token, readonly: true %>

      <%= text_input_row form, :username, autocomplete: "username", help: t("devise.registrations.new.username.help"), value: nil, required: true %>

      <% if form.object.class.require_password_on_accepting %>
        <%= password_input_row form, :password, autocomplete: "new-password" %>
        <%= password_input_row form, :password_confirmation, autocomplete: "new-password" %>
      <% end %>

      <div class="flex flex-wrap items-center gap-2">
        <%= form.submit translate("devise.registrations.new.sign_up"), class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
        <div class="ml-auto">
          <%= AltchaWidget() %>
        </div>
      </div>
    </div>
    <%= content_tag :div, t("devise.registrations.new.approval_help"), class: "px-4 py-3 rounded-lg bg-info/10 text-info mb-4" if SiteSettings.approve_signups %>
  <% end %>
</div>
