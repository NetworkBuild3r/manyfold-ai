<hr class="tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:my-4">
<ul class="tw:list-none tw:pl-0 tw:space-y-2">
  <%- if controller_name != 'sessions' %>
    <li>
      <%= link_to t(".sign_in"), new_session_path(resource_name), class: "tw:text-primary-600 tw:dark:tw:text-primary-400 hover:tw:underline" %>
    </li>
  <% end %>

  <%- if devise_mapping.registerable? && policy(:user).new? && controller_name != 'registrations' %>
    <li>
      <%= link_to t(".sign_up"), new_registration_path(resource_name), class: "tw:text-primary-600 tw:dark:tw:text-primary-400 hover:tw:underline" %>
    </li>
  <% end %>

  <%- if devise_mapping.recoverable? && policy(:"users/passwords").new? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <li>
      <%= link_to t(".forgot_your_password"), new_password_path(resource_name), class: "tw:text-primary-600 tw:dark:tw:text-primary-400 hover:tw:underline" %>
    </li>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <li>
      <%= link_to t(".didn_t_receive_confirmation_instructions"), new_confirmation_path(resource_name), class: "tw:text-primary-600 tw:dark:tw:text-primary-400 hover:tw:underline" %>
    </li>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <li>
      <%= link_to t(".didn_t_receive_unlock_instructions"), new_unlock_path(resource_name), class: "tw:text-primary-600 tw:dark:tw:text-primary-400 hover:tw:underline" %>
    </li>
  <% end %>
</ul>

<div class="tw:mt-4">
  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to t(".sign_in_with_provider", provider: ENV.fetch("OIDC_NAME", OmniAuth::Utils.camelize(provider))), omniauth_authorize_path(resource_name, provider), method: :post, class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500", data: {turbo: false} %>
    <% end %>
  <% end %>
</div>
