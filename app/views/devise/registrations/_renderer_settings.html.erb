<%= form.fields_for :renderer_settings do |renderer_settings_form| %>
  <div class="tw:rounded-xl tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:bg-white tw:dark:tw:bg-secondary-800 tw:shadow-sm tw:mb-4 tw:overflow-hidden">
    <h3 class="tw:px-4 tw:py-3 tw:bg-secondary-600 tw:text-white tw:m-0 tw:font-medium"><%= t(".heading") %></h3>
    <div class="tw:p-4 tw:text-lg tw:text-secondary-600 tw:dark:tw:text-secondary-400">
      <%= t(".description") %>
    </div>
    <div class="tw:px-4 tw:pb-4 tabular-form">
      <div>
        <%= renderer_settings_form.label :auto_load_max_size, t(".auto_load_max_size.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div>
        <%= renderer_settings_form.select :auto_load_max_size,
              [
                [t(".auto_load_max_size.never"), 0],
                [t(".auto_load_max_size.under_2"), 2],
                [t(".auto_load_max_size.under_4"), 4],
                [t(".auto_load_max_size.under_8"), 8],
                [t(".auto_load_max_size.under_16"), 16],
                [t(".auto_load_max_size.under_32"), 32],
                [t(".auto_load_max_size.under_64"), 64],
                [t(".auto_load_max_size.under_128"), 128],
                [t(".auto_load_max_size.under_256"), 256],
                [t(".auto_load_max_size.under_512"), 512],
                [t(".auto_load_max_size.under_1024"), 1024],
                [t(".auto_load_max_size.always"), 9_999_999]
              ],
              {selected: renderer_settings["auto_load_max_size"] || 9_999_999},
              {class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800"} %>
      </div>
      <div>
        <%= renderer_settings_form.label :show_grid, t(".show_grid.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div class="tw:flex tw:items-center tw:gap-2">
        <%= renderer_settings_form.check_box :show_grid, checked: renderer_settings["show_grid"], class: "tw:rounded tw:border-secondary-300 tw:text-primary-600 tw:focus:ring-primary-500 tw:h-4 tw:w-4" %>
      </div>
      <div>
        <%= renderer_settings_form.label :grid_width, t(".grid_width.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div>
        <%= renderer_settings_form.number_field :grid_width, value: renderer_settings["grid_width"], class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800" %>
      </div>
      <div>
        <%= renderer_settings_form.label :enable_pan_zoom, t(".enable_pan_zoom.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div class="tw:flex tw:items-center tw:gap-2">
        <%= renderer_settings_form.check_box :enable_pan_zoom, checked: renderer_settings["enable_pan_zoom"], class: "tw:rounded tw:border-secondary-300 tw:text-primary-600 tw:focus:ring-primary-500 tw:h-4 tw:w-4" %>
      </div>
      <div>
        <%= renderer_settings_form.label :background_colour, t(".background_colour.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div>
        <%= renderer_settings_form.color_field :background_colour, value: renderer_settings["background_colour"], class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800 tw:h-10" %>
      </div>
      <div>
        <%= renderer_settings_form.label :render_style, t(".render_style.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div>
        <%= renderer_settings_form.select :render_style, [
              [t(".render_style.original"), "original"],
              [t(".render_style.normals"), "normals"],
              [t(".render_style.lambert"), "lambert"],
              [t(".render_style.shadowed"), "shadowed"]
            ], {selected: renderer_settings["render_style"]}, {class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800"} %>
      </div>
      <div>
        <%= renderer_settings_form.label :object_colour, t(".object_colour.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div>
        <%= renderer_settings_form.color_field :object_colour, value: renderer_settings["object_colour"], class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800 tw:h-10" %>
      </div>
    </div>
  </div>
<% end %>
