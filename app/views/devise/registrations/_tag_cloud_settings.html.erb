<%= form.fields_for :tag_cloud_settings do |tag_cloud_settings_form| %>
  <div class="tw:rounded-xl tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:bg-white tw:dark:tw:bg-secondary-800 tw:shadow-sm tw:mb-4 tw:overflow-hidden">
    <h3 class="tw:px-4 tw:py-3 tw:bg-secondary-600 tw:text-white tw:m-0 tw:font-medium"><%= t(".heading") %></h3>
    <div class="tw:p-4 tabular-form">
      <div>
        <%= tag_cloud_settings_form.label :threshold, t(".threshold.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div>
        <%= tag_cloud_settings_form.number_field :threshold, value: tag_cloud_settings["threshold"], class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800" %>
      </div>
      <div>
        <%= tag_cloud_settings_form.label :heatmap, t(".heatmap.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div class="tw:flex tw:items-center tw:gap-2">
        <%= tag_cloud_settings_form.check_box :heatmap, checked: tag_cloud_settings["heatmap"], class: "tw:rounded tw:border-secondary-300 tw:text-primary-600 tw:focus:ring-primary-500 tw:h-4 tw:w-4" %>
      </div>
      <div>
        <%= tag_cloud_settings_form.label :sorting, t(".sorting.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div>
        <%= tag_cloud_settings_form.select :sorting,
              [[t(".sorting.frequency"), nil], [t(".sorting.alphabetical"), "alphabetical"]],
              {selected: tag_cloud_settings["sorting"]},
              {class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800"} %>
      </div>
      <div>
        <%= tag_cloud_settings_form.label :keypair, t(".keypair.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
      </div>
      <div class="tw:flex tw:items-center tw:gap-2">
        <%= tag_cloud_settings_form.check_box :keypair, checked: tag_cloud_settings["keypair"], class: "tw:rounded tw:border-secondary-300 tw:text-primary-600 tw:focus:ring-primary-500 tw:h-4 tw:w-4" %>
      </div>
    </div>
  </div>
<% end %>
