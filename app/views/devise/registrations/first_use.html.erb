
<h2><%= t(".title") %></h2>

<p class="tw:px-4 tw:py-3 tw:rounded-lg tw:bg-info/10 tw:text-info tw:mb-4">
 <%= t(".guidance") %>
</p>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: {method: :put, class: "tabular-form"}) do |f| %>
  <%= text_input_row f, :email, autofocus: true, autocomplete: "email", help: t(".email_help") %>
  <%= text_input_row f, :username, help: t(".username_help") %>
  <%= password_input_row f, :password, autocomplete: "new-password", help: t(".password.help_html") %>
  <%= password_input_row f, :password_confirmation, autocomplete: "new-password" %>
  <div>
    <button type="submit" class="tw:inline-flex tw:items-center tw:gap-2 tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500"><%= Icon(icon: "save", label: t(".submit")) %> <%= t(".submit") %></button>
  </div>
<% end %>
