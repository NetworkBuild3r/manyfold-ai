<h2 class="text-2xl font-bold text-secondary-900 dark:text-secondary-100 mb-4"><%= t(".title") %></h2>

<p class="flex items-center gap-2 px-4 py-3 rounded-lg bg-primary-50 text-primary-800 dark:bg-primary-900/30 dark:text-primary-200 mb-4">
  <%= t(".guidance") %>
</p>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: {method: :put, class: "tabular-form"}) do |f| %>
  <%= text_input_row f, :email, autocomplete: "email", help: t(".email_help") %>
  <%= text_input_row f, :username, help: t(".username_help") %>
  <%= password_input_row f, :password, autocomplete: "new-password", help: t(".password.help_html") %>
  <%= password_input_row f, :password_confirmation, autocomplete: "new-password" %>
  <div>
    <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500"><%= Icon(icon: "save", label: t(".submit")) %> <%= t(".submit") %></button>
  </div>
<% end %>
