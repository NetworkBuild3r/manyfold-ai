<div class="tw:rounded-xl tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:bg-white tw:dark:tw:bg-secondary-800 tw:shadow-sm tw:mb-4 tw:overflow-hidden">
  <h3 class="tw:px-4 tw:py-3 tw:bg-secondary-600 tw:text-white tw:m-0 tw:font-medium"><%= t(".heading") %></h3>
  <div class="tw:p-4 tabular-form">

    <div>
      <%= form.label :interface_language, t(".interface_language.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
    </div>
    <div>
      <%= form.select :interface_language,
            @languages,
            {selected: @user.interface_language},
            {class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800"} %>
      <small class="tw:text-sm tw:text-secondary-500 tw:dark:tw:text-secondary-400 tw:block tw:mt-1"><%= t ".interface_language.help" %></small>
    </div>

    <div>
      <%= form.label :sensitive_content_handling, t(".sensitive_content.label"), class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
    </div>
    <div>
      <%= form.select :sensitive_content_handling,
            [
              [t(".sensitive_content.show"), nil],
              [t(".sensitive_content.mask"), "mask"],
              [t(".sensitive_content.hide"), "hide"]
            ],
            {selected: @user.sensitive_content_handling},
            {class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800"} %>
      <small class="tw:text-sm tw:text-secondary-500 tw:dark:tw:text-secondary-400 tw:block tw:mt-1"><%= t ".sensitive_content.help" %></small>
    </div>

  </div>
</div>
