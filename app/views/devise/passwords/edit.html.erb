<h2 class="<%= heading_classes(:page) %> mb-4"><%= t(".change_your_password") %></h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: {method: :put, class: "tabular-form"}) do |f| %>
  <%= f.hidden_field :reset_password_token %>
  <%= password_input_row f, :password, autocomplete: "new-password", autofocus: true %>
  <%= password_input_row f, :password_confirmation, autocomplete: "new-password" %>
  <div>
    <%= f.submit translate(".change_my_password"), class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
