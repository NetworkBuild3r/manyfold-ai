<h2 class="<%= heading_classes(:page) %> mb-4"><%= t(".forgot_your_password") %></h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: {method: :post, class: "tabular-form"}) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <%= text_input_row f, :email, autocomplete: "email", autofocus: true %>
  <div>
    <%= f.submit translate(".send_me_reset_password_instructions"), class: "inline-flex items-center px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
