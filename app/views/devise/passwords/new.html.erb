<h2><%= t(".forgot_your_password") %></h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: {method: :post, class: "tabular-form"}) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <%= text_input_row f, :email, autocomplete: "email", autofocus: true %>
  <div>
    <%= f.submit translate(".send_me_reset_password_instructions"), class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
