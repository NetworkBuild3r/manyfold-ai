<%= PageTitle title: t(".title"), breadcrumbs: {
      t("follows.index.title") => follows_path
    } %>

<%= render "search_form", query: @query %>

<% if @query.present? %>

  <h3 class="text-lg font-semibold text-secondary-900 dark:text-secondary-100 mb-2"><%= t(".results") %></h3>
  <% if @actors&.any? %>
    <div class="flex flex-wrap gap-4">
      <% @actors.each do |actor| %>
        <%= ActorCard actor: actor %>
      <% end %>
    </div>
  <% else %>
    <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-info/10 text-info dark:bg-info/20">
      <%= Icon icon: "person-arms-up", label: "" %>
      <%= t(".no_results", query: @query) %>
    </div>
  <% end %>
<% end %>

<% if @recommended&.any? %>

  <h3 class="text-lg font-semibold text-secondary-900 dark:text-secondary-100 mb-2"><%= t(".recommended") %></h3>
  <div class="flex flex-wrap gap-4">
    <% @recommended.each do |actor| %>
      <%= ActorCard actor: actor %>
    <% end %>
  </div>

<% end %>
