<%= form_with model: @library, class: "tw:max-w-2xl tw:mx-auto tabular-form" do |form| %>
  <%= text_input_row form, :name %>
  <%= checkbox_input_row form, :default, help: t(".default.help"), checked: @library.default? %>
  <% unless @library.persisted? %>
    <div>
      <%= form.label :storage_service, class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
    </div>
    <div>
      <%= form.select :storage_service, Library::STORAGE_SERVICES.map { |it| [translate("libraries.storage_services.%{service}" % {service: it}), it] }, {}, {class: "tw:block tw:w-full tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800", "data-controller": "storage-service", "data-action": "change->storage-service#onChange"} %>
      <div id="options-filesystem" class="tw:rounded-lg tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:p-4 tw:mt-2 show storage-collapse tabular-form">
        <p class="tw:mb-3"><%= t ".filesystem_description_html" %></p>
        <%= text_input_row form, :path, placeholder: translate(".path.placeholder") %>
        <%= checkbox_input_row form, :create_path_if_not_on_disk, help: t(".create_path_if_not_on_disk.help") %>
      </div>
      <div id="options-s3" class="tw:rounded-lg tw:border tw:border-secondary-200 tw:dark:tw:border-secondary-600 tw:p-4 tw:mt-2 show storage-collapse tabular-form">
        <p class="tw:mb-3"><%= t ".s3_description_html" %></p>
        <%= url_input_row form, :s3_endpoint, help: t(".s3_endpoint.help"), autocomplete: false %>
        <%= text_input_row form, :s3_bucket, help: t(".s3_bucket.help"), autocomplete: false %>
        <%= text_input_row form, :s3_region, autocomplete: false %>
        <%= text_input_row form, :s3_access_key_id, autocomplete: false %>
        <%= password_input_row form, :s3_secret_access_key, autocomplete: false %>
        <%= checkbox_input_row form, :s3_path_style, help: t(".s3_path_style.help") %>
      </div>
    </div>
  <% end %>
  <%= text_input_row form, :caption, help: t(".caption.help") %>
  <%= text_input_row form, :icon, help: t(".icon.help_html"), placeholder: translate(".icon.placeholder") %>
  <%= rich_text_input_row form, :notes, help: t(".notes.help_html") %>

  <% if @library.persisted? %>
    <div>
      <%= form.label :tag_regex, class: "tw:block tw:text-sm tw:font-medium tw:text-secondary-700 tw:dark:tw:text-secondary-300" %>
    </div>
    <div id="newinput" class="tw:space-y-2">
      <% @library.tag_regex.each do |reg| %>
        <div class="tag-regex-row tw:flex tw:gap-2 tw:items-center">
          <%= text_field_tag "library[tag_regex][]", reg, class: "tw:block tw:flex-1 tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800", autocomplete: "off" %>
          <%= link_to Icon(icon: "trash", label: t("general.delete")), "", onClick: "jQuery(this).parents('.tag-regex-row')[0].remove(); return false;", class: "tw:inline-flex tw:items-center tw:px-3 tw:py-2 tw:rounded-lg tw:border tw:border-danger tw:text-danger hover:tw:bg-danger/10 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500 tw:shrink-0" %>
        </div>
      <% end %>
      <div id="regexclone" style="display: none">
        <div class="tag-regex-row tw:flex tw:gap-2 tw:items-center">
          <%= text_field_tag "library[tag_regex][]", "", class: "tw:block tw:flex-1 tw:rounded-lg tw:border tw:border-secondary-300 tw:px-3 tw:py-2 tw:shadow-sm tw:focus:ring-2 tw:focus:ring-primary-500 tw:dark:tw:border-secondary-600 tw:dark:tw:bg-secondary-800", autocomplete: "off" %>
          <%= link_to Icon(icon: "trash", label: t("general.delete")), "", onClick: "jQuery(this).parents('.tag-regex-row')[0].remove(); return false;", class: "tw:inline-flex tw:items-center tw:px-3 tw:py-2 tw:rounded-lg tw:border tw:border-danger tw:text-danger hover:tw:bg-danger/10 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500 tw:shrink-0" %>
        </div>
      </div>
      <div class="tw:mt-2">
        <%= link_to Icon(icon: "plus-square-dotted", label: t(".add_line")), "", onClick: "$('#newinput').append($('#regexclone').html()); return false;", class: "tw:inline-flex tw:items-center tw:gap-2 tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500 tw:no-underline" %>
        <span id="libraryRegexHelp" class="tw:text-sm tw:text-secondary-500 tw:dark:tw:text-secondary-400 tw:block tw:mt-1"><%= t(".tag_regex.help") %></span>
      </div>
    </div>
  <% end %>

  <div class="tw:flex tw:flex-wrap tw:items-center tw:gap-2 tw:mt-4">
    <%= form.submit translate("general.save"), class: "tw:inline-flex tw:items-center tw:px-4 tw:py-2 tw:rounded-lg tw:bg-primary-600 tw:text-white hover:tw:bg-primary-700 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500" %>

    <% if @library.persisted? %>
      <%= if policy(@library).destroy?
            link_to safe_join([Icon(icon: "trash", label: t("general.delete")), t("general.delete")], " "),
              library_path(@library.public_id),
              {
                method: :delete,
                class: "tw:ml-auto tw:inline-flex tw:items-center tw:gap-2 tw:px-4 tw:py-2 tw:rounded-lg tw:border tw:border-danger tw:text-danger hover:tw:bg-danger/10 focus-visible:tw:ring-2 focus-visible:tw:ring-primary-500 tw:no-underline",
                data: {confirm: translate(".confirm_destroy.help", count: @library.models.count)}
              }
          end %>
    <% end %>
  </div>
<% end %>
