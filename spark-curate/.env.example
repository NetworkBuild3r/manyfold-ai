# Copy to .env and adjust.

# --- Host path to Manyfold library (bind-mounted at /library) ---
# Linux (NFS already mounted):
# LIBRARY_HOST_PATH=/mnt/nas/Backups/3D-Prints
# Or on Spark if NAS is mounted there:
LIBRARY_HOST_PATH=/mnt/3D-Prints

LIBRARY_ROOT=/library
WORK_DIR=/library/.spark-curate

# --- DGX Spark APIs ---
GEMMA_URL=http://192.168.11.161:11435/v1
GEMMA_MODEL=gemma4-uncensored
CURATOR_URL=http://192.168.11.161:11436/v1
CURATOR_MODEL=qwen2.5-1.5b-instruct
NUDENET_URL=http://192.168.11.161:8090
EMBED_URL=http://192.168.11.161:8000/v1
EMBED_MODEL=BAAI/bge-m3

# --- Run policy ---
# 0 = dry-run (plan only). 1 = perform rearrangements (never deletes).
APPLY=0
MIN_CONFIDENCE=0.55
WORKERS=2
# Pilot: LIMIT=20 and ONLY_CATEGORIES=Cosplay
LIMIT=0
ONLY_CATEGORIES=
SKIP_GOOD=0
# 0 = run once and exit. e.g. 86400 = daily loop
RUN_INTERVAL_SECONDS=0

# bridge | host  (host is nicest on Linux next to Spark)
NETWORK_MODE=bridge
